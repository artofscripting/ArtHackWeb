// ── Helper functions ──────────────────────────────────────────
function entityAt(x,y){for(const e of Object.values(entities))if(e.x===x&&e.y===y)return e;return null;}
function itemAt(x,y){const found=Object.values(items).filter(it=>it.x===x&&it.y===y);return found.length?found[found.length-1]:null;}
function isBlocked(x,y){if(x<0||x>=WW||y<0||y>=WH)return true;const c=grid[y][x];if(BLOCK.has(c))return true;if(entityAt(x,y))return true;return false;}

function visionRadius(){
  let r=VR;
  for(const e of G.activeEffects)if(e.type==='sight')r+=e.value;
  for(const slot of Object.keys(G.equipped))if(G.equipped[slot])r+=G.equipped[slot].sightBonus||0;
  return Math.max(4,Math.min(30,r));
}

function playerAtk(){
  let a=2;
  for(const it of Object.values(G.equipped))if(it)a+=it.attack||0;
  a+=Math.floor(G.skills.melee/2);
  if(G.archetype==='combat_specialist')a+=2;
  for(const e of G.activeEffects)if(e.type==='attack')a+=e.value;
  return a;
}
function playerDef(){
  let d=0;
  for(const it of Object.values(G.equipped))if(it)d+=it.defense||0;
  for(const e of G.activeEffects)if(e.type==='defense')d+=e.value;
  return d;
}

function diffMult(){return{easy:0.85,normal:1.0,hard:1.20,nightmare:1.35}[G.difficulty]||1.0;}

function clampHeat(v){return Math.max(0,Math.min(5.0,v));}
function heatLevel(){return Math.min(5,Math.floor(G.heat));}
function setHeat(v){G.heat=clampHeat(v);G.heatPeak=Math.max(G.heatPeak||0,G.heat);}
function addHeat(v){setHeat(G.heat+v);}

function addSkillXP(skill,xp=1){
  if(!G._skillXP)G._skillXP={melee:0,ranged:0};
  const gain=Math.max(1,Math.floor(xp*(G.xpMult||1)));
  if(skill==='melee'||skill==='ranged'){
    G._skillXP[skill]=(G._skillXP[skill]||0)+gain;
    while(G._skillXP[skill]>=3){
      G._skillXP[skill]-=3;
      G.skills[skill]=(G.skills[skill]||0)+1;
      addLog(`${skill[0].toUpperCase()+skill.slice(1)} Lv${G.skills[skill]}!`,M.yel);
    }
  } else if(G.skills.hasOwnProperty(skill)){
    G.skills[skill]=(G.skills[skill]||0)+gain;
    addLog(`${skill[0].toUpperCase()+skill.slice(1)} Lv${G.skills[skill]}.`,M.yel);
  }
}

function addClue(text,source='clue'){
  if(G.clues>=CLUES_NEEDED)return;
  G.clues++;
  const note=`CLUE: ${text||source}`;
  G.journal.push(note);
  addLog(`Found a clue! (${G.clues}/${CLUES_NEEDED}) "${String(text||source).slice(0,50)}"`,M.tea);
  maybeArmPortal();
}

function maybeArmPortal(){
  if(G.phase==='return'&&G.clues>=CLUES_NEEDED&&!G.portalArmed){
    G.portalArmed=true;
    G.phase='portal';
    addLog('The clues align. The portal is armed — find O and go home.',M.mau);
  }
}

function adjustRep(delta,reason=''){
  if(!delta)return;
  G.rep=Math.max(-10,Math.min(10,G.rep+delta));
  const tag=delta>0?`+${delta}`:String(delta);
  addLog(`[REP ${tag}] street cred now ${G.rep}${reason?` (${reason})`:''}.`,delta>0?M.grn:M.mar);
}

function repSightMod(){
  if(G.rep>=6)return -2;
  if(G.rep>=3)return -1;
  if(G.rep<=-6)return 2;
  if(G.rep<=-3)return 1;
  return 0;
}

function nearbyTerminalIntel(range=5){
  let best=null;
  for(const[k,sp] of Object.entries(specials)){
    if(sp.kind!=='terminal')continue;
    const[x,y]=k.split(',').map(Number);
    const d=Math.abs(x-G.px)+Math.abs(y-G.py);
    if(d<=range&&(!best||d<best.d))best={...sp,x,y,d};
  }
  return best;
}

function stealthCut(){
  let cut=3+Math.floor(G.skills.evasion/4);
  if(G.archetype==='infiltrator')cut+=3;
  return cut;
}

function scaleEnemy(ent){
  if(ent._scaledFor===G.difficulty)return;
  const m=diffMult();
  const bhp=ent.baseHp||ent.maxHp||ent.hp||18;
  const batk=ent.baseAtk||ent.atk||6;
  const barm=ent.baseArm??ent.arm??1;
  const hpRatio=ent.maxHp?Math.max(0,Math.min(1,ent.hp/ent.maxHp)):1;
  ent.maxHp=Math.max(1,Math.round(bhp*m));
  ent.hp=Math.min(ent.maxHp,Math.max(1,Math.round(ent.maxHp*hpRatio)));
  ent.atk=Math.max(1,Math.round(batk*m));
  ent.arm=Math.max(0,Math.round(barm*m));
  ent._scaledFor=G.difficulty;
}

function moduleForEnemy(name){
  const n=name.toLowerCase();
  if(n.includes('jailer'))return'keylog_implant';
  if(n.includes('skeleton')||n.includes('necromancer'))return'daemon_rootkit';
  if(n.includes('captain')||n.includes('mercenary'))return'override_bus';
  if(n.includes('guard'))return'process_mask';
  if(n.includes('hound')||n.includes('wolf'))return'arp_sweep_kit';
  if(n.includes('bat'))return'cam_jammer';
  if(n.includes('orc'))return'buffer_exploit';
  if(n.includes('rat'))return'sniffer_patch';
  return null;
}

function unlockModule(module, source){
  if(!module||G.modules.has(module))return;
  G.modules.add(module);
  const tool=MODULE_TO_TOOL[module];
  if(tool)G.tools.add(tool);
  addLog(`Recovered ${module} from ${source}.`,M.pch);
}

function awardKill(ent,cause='defeated'){
  G.stats.kills++;
  adjustRep(-1,'left a body');
  const coin=Math.floor(ri(25,100)*diffMult())+(G.archetype==='combat_specialist'?ri(10,30):0);
  G.walletCp+=coin;
  unlockModule(moduleForEnemy(ent.name),ent.name);
  if(ent.id===G.responderID)G.responderID=null;
  delete entities[ent.id];
  addLog(`You ${cause} ${ent.name}! (+${coin}cp)`,M.grn);
  clearHeatIfNoVisibleHostiles();
}

function visibleHostiles(){
  return Object.values(entities).filter(e=>e.hostile&&visible.has(`${e.x},${e.y}`));
}

function clearHeatIfNoVisibleHostiles(){
  if(visibleHostiles().length===0&&G.heat>0){
    setHeat(0);
    addLog('No visible hostiles remain. Heat drops to 0.',M.sky);
  }
}

function rootedTerminals(){
  return Object.entries(specials)
    .filter(([,sp])=>sp.kind==='terminal'&&sp.hacked)
    .map(([key,sp])=>{const[x,y]=key.split(',').map(Number);return{key,x,y,sp};});
}

function terminalResource(control){return TERM_RES[control]||null;}

function resecureTerminal(t){
  const sp=specials[t.key];
  if(!sp||sp.kind!=='terminal')return;
  const ssid=sp.ssid||'CastleNet';
  sp.hacked=false;sp.portscanned=false;sp.vulnscanned=false;
  if(sp.botnet)sp.botnet=false;
  const res=terminalResource(sp.control);
  if(res&&G.resources[res])G.resources[res].delete(ssid);
  addLog(`[SOC] Incident response re-secured ${ssid}. Root revoked.`,M.red);
}

