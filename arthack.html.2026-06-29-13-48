const canvas=document.getElementById('c');
const ctx=canvas.getContext('2d');
const dpr=window.devicePixelRatio||1;

function setupLayout(){
  const sw=window.innerWidth,sh=window.innerHeight;
  IS_PORTRAIT=sh>sw;
  if(IS_PORTRAIT){
    CW=Math.max(7,Math.floor(sw/50));
    CH=Math.round(CW*1.75);
    VW=Math.floor(sw/CW);
    VH=26;LH=5;SW=0;
    // sidebar/log use a distinctly smaller font than game tiles
    SCH=Math.max(8,Math.round(CH*0.70));
    SCW=Math.max(6,Math.round(CW*0.78));
    const sbRows=TOUCH_MODE?4:5; // touch mode: drop key-hint row + one info row
    P_SB_H=sbRows*SCH;
    CAN_W=VW*CW;
    CAN_H=VH*CH+P_SB_H+LH*SCH; // log also uses SCH rows
  }else{
    CW=10;CH=18;VW=80;VH=26;LH=8;SW=30;
    SCH=13;SCW=8;P_SB_H=0;
    CAN_W=(VW+SW)*CW;CAN_H=(VH+LH)*CH;
  }
  canvas.width=CAN_W*dpr;canvas.height=CAN_H*dpr;
  canvas.style.width=CAN_W+'px';canvas.style.height=CAN_H+'px';
  ctx.setTransform(dpr,0,0,dpr,0,0);
  ctx.font=`${CH}px 'Courier New',monospace`;
  ctx.textBaseline='top';ctx.textAlign='left';
  applyScale();
}

function applyScale(){
  const sw=window.innerWidth,sh=window.innerHeight;
  const tuiEl=document.getElementById('touch-ui');
  const ctxEl=document.getElementById('ctx-bar');
  const tuiH=(TOUCH_MODE&&tuiEl&&tuiEl.offsetHeight)?tuiEl.offsetHeight:0;
  const ctxH=(ctxEl&&ctxEl.offsetHeight)?ctxEl.offsetHeight:0;
  const availW=sw,availH=sh-tuiH-ctxH;
  const scale=Math.min(availW/CAN_W,availH/CAN_H);
  const scaledW=CAN_W*scale,scaledH=CAN_H*scale;
  canvas.style.transformOrigin='top left';
  canvas.style.transform=`scale(${scale})`;
  canvas.style.left=Math.round((availW-scaledW)/2)+'px';
  canvas.style.top=ctxH+Math.max(0,Math.round((availH-scaledH)/2))+'px';
}

setupLayout();

