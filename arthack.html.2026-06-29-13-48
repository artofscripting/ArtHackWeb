function drawMinimap(){
  const scale=6;
  const mw=Math.floor(WW/scale),mh=Math.floor(WH/scale);
  const ox=Math.floor((CAN_W-mw*2)/2),oy=Math.floor((CAN_H-mh*2)/2);
  ctx.fillStyle='rgba(17,17,27,0.92)';ctx.fillRect(ox-4,oy-4,mw*2+8,mh*2+12+CH);
  ctx.fillStyle=M.lav;ctx.fillText('MINIMAP  [m] close',ox,oy-4);
  for(let my=0;my<mh;my++){
    for(let mx=0;mx<mw;mx++){
      let best=VOID,bestP=-1;
      for(let dy=0;dy<scale;dy++)for(let dx=0;dx<scale;dx++){
        const wx=mx*scale+dx,wy=my*scale+dy;
        if(wx>=WW||wy>=WH)continue;
        if(!seen.has(`${wx},${wy}`))continue;
        const c=grid[wy][wx];
        const p=MINI_PR[c]??-1;
        if(p>bestP){bestP=p;best=c;}
      }
      if(best===VOID)continue;
      ctx.fillStyle=FG[best]||M.s0;
      ctx.fillRect(ox+mx*2,oy+my*2,2,2);
    }
  }
  // Player dot
  ctx.fillStyle=M.grn;
  ctx.fillRect(ox+Math.floor(G.px/scale)*2,oy+Math.floor(G.py/scale)*2,3,3);
}

