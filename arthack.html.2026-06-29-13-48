function overlayText(lines,ox=2,oy=1){
  // in portrait use the smaller sidebar font so panels fit narrow screens
  const cw=IS_PORTRAIT?SCW:CW;
  const ch=IS_PORTRAIT?SCH:CH;
  ctx.font=`${ch}px 'Courier New',monospace`;
  let row=oy;
  for(const entry of lines){
    const[text='',color=M.txt,x=ox]=entry;
    const px=x*cw;
    const maxC=Math.max(8,Math.floor((CAN_W-px)/cw));
    if(text==='---'){
      ctx.fillStyle=M.s1;ctx.fillText('─'.repeat(maxC),px,row*ch);row++;continue;
    }
    ctx.fillStyle=color;
    const str=String(text);
    // auto-center box-draw titles (═══ ... ═══)
    let drawX=px;
    if(str.charCodeAt(0)===0x2550){drawX=Math.max(0,Math.floor((CAN_W-str.length*cw)/2));}
    if(str.length<=maxC){
      ctx.fillText(str,drawX,row*ch);row++;
    }else{
      // word-wrap; preserve leading indent
      const indent=str.match(/^(\s*)/)[0];
      const words=str.trimStart().split(' ');
      let ln=indent;
      for(const w of words){
        const test=ln.length>indent.length?ln+' '+w:ln+w;
        if(test.length>maxC&&ln.length>indent.length){
          ctx.fillText(ln,px,row*ch);row++;ln=indent+w;
        }else{ln=test;}
      }
      if(ln){ctx.fillText(ln,px,row*ch);row++;}
    }
  }
  ctx.font=`${CH}px 'Courier New',monospace`;
  return row;
}

