function computeVisible(radius){
  const px=G.px,py=G.py;
  const vis=new Set([`${px},${py}`]);
  for(const[ca,sa] of RAYS){
    for(let r=1;r<=radius;r++){
      const cx=Math.round(px+ca*r),cy=Math.round(py+sa*r);
      if(cx<0||cx>=WW||cy<0||cy>=WH)break;
      const cell=grid[cy][cx];
      if(cell===VOID)break;
      vis.add(`${cx},${cy}`);
      if(OPAQUE.has(cell))break;
    }
  }
  visible=vis;
  for(const k of vis)seen.add(k);
}

function revealCurrentLevel(){
  for(let y=0;y<WH;y++)for(let x=0;x<WW;x++)if(getc(grid,x,y)!==VOID)seen.add(`${x},${y}`);
}

