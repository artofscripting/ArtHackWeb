function logOverlayRows(width=92){
  const rows=[];
  for(const entry of LOG){
    const prefix=`[${String(entry.turn).padStart(4,'0')}] `;
    const text=String(entry.msg||'');
    let line=prefix+text;
    while(line.length>width){
      rows.push({msg:line.slice(0,width),color:entry.color||M.txt});
      line='      '+line.slice(width);
    }
    rows.push({msg:line,color:entry.color||M.txt});
  }
  if(!rows.length)rows.push({msg:'(no log entries yet)',color:M.sub});
  return rows;
}

function logOverlayGeometry(){
  const cw=IS_PORTRAIT?SCW:CW,ch=IS_PORTRAIT?SCH:CH;
  const cols=Math.max(1,Math.floor(CAN_W/cw)),screenRows=Math.max(1,Math.floor(CAN_H/ch));
  const w=Math.max(32,Math.min(cols-4,96));
  const h=Math.max(10,Math.min(screenRows-4,30));
  const left=Math.max(1,Math.floor((cols-w)/2));
  const top=Math.max(1,Math.floor((screenRows-h)/2));
  const contentW=Math.max(8,w-4),contentH=Math.max(1,h-5);
  return{cw,ch,w,h,left,top,contentW,contentH};
}
function openLogOverlay(){
  G.overlay='log';
  const geo=logOverlayGeometry();
  const rows=logOverlayRows(geo.contentW);
  G.logScroll=Math.max(0,rows.length-geo.contentH);
}

function drawLogOverlay(){
  const geo=logOverlayGeometry();
  const {cw,ch,w,h,left,top,contentW,contentH}=geo;
  const rows=logOverlayRows(contentW);
  const maxScroll=Math.max(0,rows.length-contentH);
  G.logScroll=Math.max(0,Math.min(G.logScroll,maxScroll));
  ctx.font=`${ch}px 'Courier New',monospace`;
  ctx.fillStyle=M.crust;ctx.fillRect(left*cw,top*ch,w*cw,h*ch);
  ctx.fillStyle=M.s1;
  ctx.fillText('╔'+'═'.repeat(w-2)+'╗',left*cw,top*ch);
  for(let i=1;i<h-1;i++)ctx.fillText('║'+' '.repeat(w-2)+'║',left*cw,(top+i)*ch);
  ctx.fillText('╚'+'═'.repeat(w-2)+'╝',left*cw,(top+h-1)*ch);
  ctx.fillStyle=M.lav;ctx.fillText(' LOG PANEL ',(left+3)*cw,top*ch);
  const visibleRows=rows.slice(G.logScroll,G.logScroll+contentH);
  for(let i=0;i<visibleRows.length;i++){
    ctx.fillStyle=visibleRows[i].color||M.txt;
    ctx.fillText(visibleRows[i].msg.slice(0,contentW),(left+2)*cw,(top+2+i)*ch);
  }
  const page=` ${G.logScroll+1}-${Math.min(rows.length,G.logScroll+contentH)}/${rows.length}  ↑↓ PgUp/PgDn Home/End  Esc close `;
  ctx.fillStyle=M.sub;ctx.fillText(page.slice(0,contentW),(left+2)*cw,(top+h-2)*ch);
  ctx.font=`${CH}px 'Courier New',monospace`;
}

