const RAYS=[];
for(let i=0;i<720;i++){const a=2*Math.PI*i/720;RAYS.push([Math.cos(a),Math.sin(a)]);}
const OPAQUE=new Set(['#','=']);

// ══════════════════════════════════════════════════════════════
//  Level state (current level)
// ══════════════════════════════════════════════════════════════
let grid=[],rooms=[],items={},entities={},doors={},specials={},seen=new Set(),visible=new Set();
let NUM_LEVELS=ri(8,12);
let levelStore=[];
let stairLinks={};

function mkGrid(){return Array.from({length:WH},()=>Array(WW).fill(VOID));}
function setc(g,x,y,c){if(x>=0&&x<WW&&y>=0&&y<WH)g[y][x]=c;}
function getc(g,x,y){if(x<0||x>=WW||y<0||y>=WH)return VOID;return g[y][x];}

const BLOCK=new Set(['#','=',' ']);

// ── Dungeon generation ────────────────────────────────────────
function stampBox(g,x0,y0,w,h){
  for(let j=0;j<h;j++)for(let i=0;i<w;i++){
    const edge=i===0||j===0||i===w-1||j===h-1;
    setc(g,x0+i,y0+j,edge?'#':'.');
  }
}

function roomWallAt(rms,x,y){
  return rms.find(r=>x>=r.x0&&x<r.x0+r.w&&y>=r.y0&&y<r.y0+r.h&&
    (x===r.x0||x===r.x0+r.w-1||y===r.y0||y===r.y0+r.h-1))||null;
}
function corridorCell(g,drs,rms,x,y){
  if(x<0||x>=WW||y<0||y>=WH)return;
  const c=getc(g,x,y);
  if(c===VOID){setc(g,x,y,'.');}
  else if(c==='#'){
    const rm=roomWallAt(rms,x,y);
    const key=`${x},${y}`;
    setc(g,x,y,'+');
    if(!drs[key]){drs[key]={locked:false,desc:'doorway',explored:true,room:rm?rm.id:''};}
  }
}
function hcor(g,drs,rms,x1,x2,y){for(let x=Math.min(x1,x2);x<=Math.max(x1,x2);x++){corridorCell(g,drs,rms,x,y);if(rf()<0.07)corridorCell(g,drs,rms,x,y+(ri(0,1)?1:-1));}}
function vcor(g,drs,rms,x,y1,y2){for(let y=Math.min(y1,y2);y<=Math.max(y1,y2);y++){corridorCell(g,drs,rms,x,y);if(rf()<0.07)corridorCell(g,drs,rms,x+(ri(0,1)?1:-1),y);}}

function corridorBetween(g,drs,rms,r1,r2){
  // Route center-to-center through interior floor cells; corridorCell punches
  // doors through any walls encountered, so no corner-blocking can disconnect rooms.
  const cx1=r1.x0+Math.floor(r1.w/2),cy1=r1.y0+Math.floor(r1.h/2);
  const cx2=r2.x0+Math.floor(r2.w/2),cy2=r2.y0+Math.floor(r2.h/2);
  if(rf()<0.5){hcor(g,drs,rms,cx1,cx2,cy1);vcor(g,drs,rms,cx2,cy1,cy2);}
  else{vcor(g,drs,rms,cx1,cy1,cy2);hcor(g,drs,rms,cx1,cx2,cy2);}
}

function floorCells(g,r){
  const f=[];
  for(let y=r.y0+1;y<r.y0+r.h-1;y++)for(let x=r.x0+1;x<r.x0+r.w-1;x++)if(getc(g,x,y)==='.')f.push([x,y]);
  return f;
}

function nearestRoomCenter(rms,x,y){
  let best=null,bd=1e9;
  for(const r of rms){const cx=r.x0+Math.floor(r.w/2),cy=r.y0+Math.floor(r.h/2),d=Math.abs(cx-x)+Math.abs(cy-y);if(d<bd){bd=d;best={cx,cy,r};}}
  return best;
}

// ── Device/subnet helpers ─────────────────────────────────────
function fhex(n){return Array.from({length:n},()=>ri(0,15).toString(16)).join('').toUpperCase();}
function genMac(){return`DE:AD:${fhex(2)}:${fhex(2)}:${fhex(2)}:${fhex(2)}`;}
function floorSubnet(l){return{mgmt:`10.${l+1}.1`,cam:`10.${l+1}.2`,dev:`10.${l+1}.3`,ep:`192.168.${l+1}`};}
function terminalIP(ctrl,lvl){const s=floorSubnet(lvl);return`${s[CTRL_SUBNET[ctrl]||'ep']}.${ri(10,250)}`;}
function terminalHostname(ctrl,idx){return`${CTRL_HOST[ctrl]||'SRV'}-${String(idx).padStart(2,'0')}`;}

let _rid=0;
function genLevel(lvlNum){
  const g=mkGrid(),rms=[],drs={},sps={};
  const growth=1.3**lvlNum,zgrow=1.16**lvlNum;
  const zcols=Math.min(Math.max(ZONE_COLS,Math.round(ZONE_COLS*zgrow)),Math.max(6,Math.floor(WW/10)));
  const zrows=Math.min(Math.max(ZONE_ROWS,Math.round(ZONE_ROWS*zgrow)),Math.max(4,Math.floor(WH/8)));
  const zw=Math.floor(WW/zcols),zh=Math.floor(WH/zrows);
  const themes=[...THEMES[lvlNum%THEMES.length]];sh(themes);
  const rgrid=Array.from({length:zrows},()=>Array(zcols).fill(null));
  const rscale=Math.min(3.8,growth);
  let ti=0;
  for(let row=0;row<zrows;row++){
    for(let col=0;col<zcols;col++){
      const xmin=col*zw+2,xmax=Math.min(WW-2,(col+1)*zw-2);
      const ymin=row*zh+2,ymax=Math.min(WH-2,(row+1)*zh-2);
      if(xmax-xmin<6||ymax-ymin<5)continue;
      let rw=ri(Math.max(6,Math.floor(zw*0.44)),Math.max(7,Math.floor(zw*0.72)));
      let rh=ri(Math.max(5,Math.floor(zh*0.42)),Math.max(6,Math.floor(zh*0.70)));
      rw=Math.min(Math.floor(rw*Math.min(1.2,0.9+0.06*rscale)),26,xmax-xmin-1);
      rh=Math.min(Math.floor(rh*Math.min(1.2,0.9+0.06*rscale)),16,ymax-ymin-1);
      if(rw<5||rh<4)continue;
      const x0=ri(xmin,Math.max(xmin,xmax-rw));
      const y0=ri(ymin,Math.max(ymin,ymax-rh));
      const id=`l${lvlNum}r${col}_${row}`;
      const name=themes[ti++%themes.length];
      stampBox(g,x0,y0,rw,rh);
      const r={id,name,x0,y0,w:rw,h:rh};
      rms.push(r);rgrid[row][col]=r;
    }
  }
  // Fallback single room
  if(!rms.length){
    const rw=Math.min(WW-4,Math.max(8,Math.floor(12*Math.min(3.8,growth))));
    const rh=Math.min(WH-4,Math.max(6,Math.floor(7*Math.min(3.8,growth))));
    const x0=Math.max(2,Math.floor((WW-rw)/2)),y0=Math.max(2,Math.floor((WH-rh)/2));
    stampBox(g,x0,y0,rw,rh);
    const r={id:`l${lvlNum}r0_0`,name:ch(themes),x0,y0,w:rw,h:rh};
    rms.push(r);rgrid[0]=[r,...Array(zcols-1).fill(null)];
  }
  // Connect zones
  for(let row=0;row<zrows;row++)for(let col=0;col<zcols;col++){
    const r1=rgrid[row][col];if(!r1)continue;
    if(col+1<zcols&&rgrid[row][col+1])corridorBetween(g,drs,rms,r1,rgrid[row][col+1]);
    if(row+1<zrows&&rgrid[row+1][col])corridorBetween(g,drs,rms,r1,rgrid[row+1][col]);
  }
  // Extra random connections
  for(let i=0;i<3;i++)if(rms.length>=2){const[a,b]=sm(rms,2);corridorBetween(g,drs,rms,a,b);}
  // Infill small rooms
  const target=ri(28,48)+Math.floor(18*growth);
  let added=0,tries=0;
  while(added<target&&tries<1200){
    tries++;
    const w=rf()<0.2?ri(9,14):ri(6,11),h=rf()<0.2?ri(6,10):ri(4,8);
    const x0=ri(2,WW-w-3),y0=ri(2,WH-h-3);
    let free=true;
    outer:for(let y=y0;y<y0+h;y++)for(let x=x0;x<x0+w;x++){if(getc(g,x,y)!==VOID){free=false;break outer;}}
    if(!free)continue;
    const near=nearestRoomCenter(rms,x0+Math.floor(w/2),y0+Math.floor(h/2));
    if(!near||Math.abs(near.cx-(x0+Math.floor(w/2)))+Math.abs(near.cy-(y0+Math.floor(h/2)))>52)continue;
    stampBox(g,x0,y0,w,h);
    const rid=`l${lvlNum}s${added}_${tries}`;
    const nr={id:rid,name:ch(["Closet","Cache","Antechamber","Hideout","Niche","Store Nook"]),x0,y0,w,h};
    rms.push(nr);
    corridorBetween(g,drs,rms,nr,near.r);
    added++;
  }
  // Gate on final level
  if(lvlNum===NUM_LEVELS-1){
    const gr=rgrid[0]?rgrid[0][zcols-1]||rms[rms.length-1]:rms[rms.length-1];
    if(gr){const gx=gr.x0+Math.floor(gr.w/2),gy=gr.y0+1;setc(g,gx,gy,'>');sps[`${gx},${gy}`]={kind:'gate'};}
    const pr=rms.find(r=>r!==gr&&floorCells(g,r).length)||gr;
    if(pr){
      const pf=floorCells(g,pr).filter(([x,y])=>!sps[`${x},${y}`]&&getc(g,x,y)==='.');
      if(pf.length){const[px,py]=ch(pf);setc(g,px,py,'O');sps[`${px},${py}`]={kind:'portal'};}
    }
  }
  // Starting room id fix
  if(!rms.find(r=>r.id===`l${lvlNum}r0_0`)&&rms.length)rms[0].id=`l${lvlNum}r0_0`;
  return{g,rms,drs,sps,lvlNum};
}

function populateLevel(snap){
  const{g,rms,drs,sps,lvlNum}=snap;
  const itms={},ents={};
  sh(rms);
  // Starting room guaranteed
  const startRm=rms.find(r=>r.id===`l${lvlNum}r0_0`)||rms[0];

  // Enemies
  const pool=lvlNum>=2?ENT_POOL:ENT_POOL.slice(0,10);
  const nents=Math.max(4,NUM_LEVELS+3-lvlNum);
  for(let i=0;i<nents;i++){
    const room=rms[i%rms.length];
    const f=floorCells(g,room);
    if(!f.length)continue;
    const [ex,ey]=ch(f);
    const [echar,ename,edesc,esight,ehp,eatk,earm]=ch(pool);
    const eid=`en${++_rid}`;
    ents[eid]={id:eid,x:ex,y:ey,char:echar,name:ename,desc:edesc,
      hostile:true,sight:esight,alerted:false,alertTimer:0,
      hp:ehp,maxHp:ehp,atk:eatk,arm:earm,baseHp:ehp,baseAtk:eatk,baseArm:earm,
      patrolA:[ex,ey],patrolB:[ex,ey],patrolStep:0};
  }

  // Lock 35-50% of non-explored doors
  const doorList=Object.entries(drs).filter(([,d])=>!d.locked&&!d.explored);
  sh(doorList);
  const nlock=Math.max(2,Math.floor(doorList.length*ri(35,50)/100));
  for(let i=0;i<Math.min(nlock,doorList.length);i++){
    const[dkey,dinfo]=doorList[i];
    dinfo.locked=true;
    const[dx,dy]=dkey.split(',').map(Number);
    setc(g,dx,dy,'=');
    // Drop a key in a different room
    const krooms=rms.filter(r=>r.id!==dinfo.room)||rms;
    const kr=ch(krooms);
    const kf=floorCells(g,kr);
    if(kf.length){
      const[kx,ky]=ch(kf);
      const kid=`it${++_seq}`;
      itms[kid]={...mkItem({char:'k',name:'iron key',desc:'opens a heavy lock',kind:'key',weight:0.5,valueCp:40}),id:kid,x:kx,y:ky};
      setc(g,kx,ky,'k');
    }
  }

  // Trapdoors on levels 1+
  if(lvlNum>0){
    for(let i=0;i<ri(1,2);i++){
      const room=ch(rms);const f=floorCells(g,room);
      if(f.length){const[tx,ty]=ch(f);setc(g,tx,ty,'T');sps[`${tx},${ty}`]={kind:'trapdoor',targetLevel:lvlNum-1};}
    }
  }

  // Terminals
  const ctrlBasic=['doors','locks','loot','gates','dungeon','security'];
  const ctrlMid=['cameras','alarms','comm','vault','power','db'];
  const ctrlAdv=['auth','scada','radio','firmware','backup','cloud'];
  const ctrlApex=['registry','webshell','vpn','container'];
  let ctrlPool=lvlNum<2?ctrlBasic:lvlNum<5?[...ctrlBasic,...ctrlMid]:lvlNum<7?[...ctrlBasic,...ctrlMid,...ctrlAdv]:[...ctrlBasic,...ctrlMid,...ctrlAdv,...ctrlApex];
  const tcands=[...rms];sh(tcands);
  const nterms=Math.max(3,Math.floor((rms.length+1)/2));
  const termSpecs=[];
  let tidx=0;
  for(let i=0;i<nterms;i++){
    const room=tcands[tidx++%tcands.length];
    const f=floorCells(g,room).filter(([x,y])=>!sps[`${x},${y}`]);
    if(!f.length)continue;
    const[tx,ty]=ch(f);
    const ctrl=ch(ctrlPool);
    const ssid=`CastleNet-${lvlNum}-${i+1}`;
    const tier=Math.max(1,Math.min(3,1+Math.floor(lvlNum/2)));
    setc(g,tx,ty,'!');
    const hp=lvlNum>=1?rf()<0.12:false;
    sps[`${tx},${ty}`]={kind:'terminal',ssid,control:ctrl,tier,hacked:false,honeypot:hp,botnet:false,ports:[],
      mac:genMac(),ip:terminalIP(ctrl,lvlNum),hostname:terminalHostname(ctrl,i+1)};
    termSpecs.push([tx,ty,ssid,tier]);
  }

  // Tutorial terminal in start room
  if(lvlNum===0&&startRm){
    const tf=floorCells(g,startRm).filter(([x,y])=>!sps[`${x},${y}`]);
    if(tf.length){
      const[tx,ty]=tf[0];
      setc(g,tx,ty,'!');
      sps[`${tx},${ty}`]={kind:'terminal',ssid:'CastleNet-TUTORIAL',control:'doors',tier:1,hacked:false,honeypot:false,botnet:false,tutorial:true,ports:[],
        mac:genMac(),ip:terminalIP('doors',0),hostname:'DCTRL-00'};
    }
  }

  // Wire terminal security (lock nearby doors)
  for(const[tx,ty,ssid,tier] of termSpecs){
    const cdoors=Object.entries(drs).filter(([k,d])=>{
      const[dx,dy]=k.split(',').map(Number);
      return Math.abs(dx-tx)+Math.abs(dy-ty)<=20&&!d.explored&&!d.hack_ssid;
    });
    sh(cdoors);
    for(let i=0;i<Math.min(ri(2,4),cdoors.length);i++){
      const[dk,di]=cdoors[i];
      di.locked=true;di.hack_locked=true;di.hack_ssid=ssid;
      const[dx,dy]=dk.split(',').map(Number);setc(g,dx,dy,'=');
    }
    // Hack chests near terminal
    const room=rms.find(r=>tx>=r.x0&&tx<r.x0+r.w&&ty>=r.y0&&ty<r.y0+r.h);
    if(room){
      const cf=floorCells(g,room).filter(([x,y])=>!sps[`${x},${y}`]&&!(x===tx&&y===ty));
      sh(cf);
      const nc=ri(2,3);
      for(let i=0;i<Math.min(nc,cf.length);i++){
        const[cx,cy]=cf[i];
        setc(g,cx,cy,'&');
        sps[`${cx},${cy}`]={kind:'hack_chest',ssid,locked:true,loot:[randLoot(lvlNum)]};
      }
    }
  }

  // Shop
  const shopRoom=lvlNum===0?(rms.find(r=>r.id===`l0r0_0`)||ch(rms)):ch(rms);
  {const f=floorCells(g,shopRoom).filter(([x,y])=>!sps[`${x},${y}`]);
   if(f.length){const[sx,sy]=ch(f);setc(g,sx,sy,'%');sps[`${sx},${sy}`]={kind:'shop',name:`Level ${lvlNum} Quartermaster`,stock:shopStock(lvlNum),nextRestock:ri(30,90)};}}

  // Crafting stations
  const stHosts=lvlNum===0?[startRm,startRm]:sm(rms,Math.min(2,rms.length));
  const usedCells=new Set();
  for(const[stKind,stRoom] of [['anvil',stHosts[0]],['table',stHosts[1]]].filter(([,r])=>r)){
    const f=floorCells(g,stRoom).filter(([x,y])=>getc(g,x,y)==='.'&&!sps[`${x},${y}`]&&!usedCells.has(`${x},${y}`));
    if(f.length){const[cx,cy]=ch(f);usedCells.add(`${cx},${cy}`);const gl=stKind==='anvil'?'A':'F';setc(g,cx,cy,gl);sps[`${cx},${cy}`]={kind:'station',station:stKind};}
  }

  // Small satchel in start room (level 0)
  if(lvlNum===0&&startRm){
    const f=floorCells(g,startRm).filter(([x,y])=>getc(g,x,y)==='.'&&!sps[`${x},${y}`]);
    if(f.length){const[sx,sy]=ch(f);const bp={...BPACKS[0],id:`it${++_seq}`,x:sx,y:sy};itms[bp.id]=bp;setc(g,sx,sy,'[');}
  }

  // Loot in every room + loot chests
  for(const room of rms){
    const f=floorCells(g,room).filter(([x,y])=>getc(g,x,y)==='.'&&!sps[`${x},${y}`]);
    sh(f);
    for(let i=0;i<ri(2,4)&&f.length;i++){
      const[lx,ly]=f.pop();
      const it={...randLoot(lvlNum),id:`it${++_seq}`,x:lx,y:ly};
      itms[it.id]=it;setc(g,lx,ly,it.char);
    }
    if(f.length&&rf()<0.85){
      const[cx,cy]=f.pop();
      setc(g,cx,cy,'X');
      sps[`${cx},${cy}`]={kind:'loot_chest',loot:[randLoot(lvlNum),randLoot(lvlNum),randLoot(lvlNum)],opened:false};
    }
  }

  // Clues for phase 'return' (scattered across all levels)
  const cluerooms=sm(rms,Math.min(2,rms.length));
  for(const r of cluerooms){
    if(rf()<0.3){
      const f=floorCells(g,r).filter(([x,y])=>getc(g,x,y)==='.');
      if(f.length){const[cx,cy]=ch(f);const it=mkItem({char:'*',name:'scrap of parchment',desc:ch(CLUE_NOTES),kind:'clue',weight:0.1,valueCp:20});it.id=`it${++_seq}`;it.x=cx;it.y=cy;itms[it.id]=it;setc(g,cx,cy,'*');}
    }
  }

  snap.itms=itms;snap.ents=ents;
}

function snapshot(){
  return{
    grid:grid.map(r=>[...r]),
    rooms:[...rooms],
    items:{...items},
    entities:{...entities},
    doors:{...Object.fromEntries(Object.entries(doors).map(([k,v])=>[k,{...v}]))},
    specials:{...Object.fromEntries(Object.entries(specials).map(([k,v])=>[k,{...v}]))},
    seen:new Set(seen),
    visible:new Set()
  };
}
function restoreSnap(snap){
  grid=snap.grid.map(r=>[...r]);
  rooms=[...snap.rooms];
  items={...snap.items};
  entities={...snap.entities};
  doors={...Object.fromEntries(Object.entries(snap.doors).map(([k,v])=>[k,{...v}]))};
  specials={...Object.fromEntries(Object.entries(snap.specials).map(([k,v])=>[k,{...v}]))};
  seen=new Set(snap.seen);
  visible=new Set();
}

function placeAllStairs(){
  for(let l=0;l<NUM_LEVELS-1;l++){
    const lo=levelStore[l],hi=levelStore[l+1];
    if(!lo||!hi)continue;
    const loRooms=lo.rooms.filter(r=>r.id!==`l0r0_0`||l>0);
    if(!loRooms.length)continue;
    const loRoom=ch(loRooms);
    const loFloor=floorCells(lo.grid,loRoom);
    if(!loFloor.length)continue;
    const[lx,ly]=ch(loFloor);
    const hiRoom=ch(hi.rooms);
    const hiFloor=floorCells(hi.grid,hiRoom);
    if(!hiFloor.length)continue;
    const[hx,hy]=ch(hiFloor);
    lo.grid[ly][lx]='<';
    lo.specials[`${lx},${ly}`]={kind:'stairs_up',targetLevel:l+1,targetX:hx,targetY:hy};
    stairLinks[`${l}:${lx},${ly}`]={dir:'up',targetLevel:l+1,targetX:hx,targetY:hy};
    hi.grid[hy][hx]='V';
    hi.specials[`${hx},${hy}`]={kind:'stairs_down',targetLevel:l,targetX:lx,targetY:ly};
    stairLinks[`${l+1}:${hx},${hy}`]={dir:'down',targetLevel:l,targetX:lx,targetY:ly};
  }
}

function generateDungeon(){
  levelStore=[];stairLinks={};_rid=0;
  for(let l=0;l<NUM_LEVELS;l++){
    const snap=genLevel(l);
    populateLevel(snap);
    // Convert snap format to storable
    levelStore.push({grid:snap.g,rooms:snap.rms,items:snap.itms,entities:snap.ents,doors:snap.drs,specials:snap.sps,seen:new Set(),visible:new Set()});
  }
  placeAllStairs();
  // Load level 0
  const s0=levelStore[0];
  grid=s0.grid.map(r=>[...r]);rooms=[...s0.rooms];
  items={...s0.items};entities={...s0.entities};
  doors={...Object.fromEntries(Object.entries(s0.doors).map(([k,v])=>[k,{...v}]))};
  specials={...Object.fromEntries(Object.entries(s0.specials).map(([k,v])=>[k,{...v}]))};
  seen=new Set();visible=new Set();
  // Place player in start room
  const startRoom=rooms.find(r=>r.id==='l0r0_0')||rooms[0];
  if(startRoom){
    const f=floorCells(grid,startRoom);
    if(f.length){[G.px,G.py]=f[0];}
    else{G.px=startRoom.x0+1;G.py=startRoom.y0+1;}
  }
  initEnemyPatrols();
}

function initEnemyPatrols(){
  for(const e of Object.values(entities)){
    if(!e.hostile||e.isResponder)continue;
    scaleEnemy(e);
    const r=rooms.find(r=>e.x>=r.x0&&e.x<r.x0+r.w&&e.y>=r.y0&&e.y<r.y0+r.h);
    if(!r)continue;
    const f=floorCells(grid,r).filter(([x,y])=>!(x===e.x&&y===e.y));
    if(f.length){
      const far=f.reduce((best,p)=>Math.abs(p[0]-e.x)+Math.abs(p[1]-e.y)>Math.abs(best[0]-e.x)+Math.abs(best[1]-e.y)?p:best,f[0]);
      e.patrolA=[e.x,e.y];e.patrolB=[...far];e.patrolStep=0;
    }
  }
}

