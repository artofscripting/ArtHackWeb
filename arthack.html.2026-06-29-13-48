function emitHackLogs(term,loadout){
  const t={ip:term.ip||'10.0.0.1',mac:term.mac||'DE:AD:BE:EF:00:01',
    hostname:term.hostname||term.control||'UNKNOWN',ssid:term.ssid};
  const tools=[...BUILTIN_TOOLS,...loadout.map(m=>MODULE_TO_TOOL[m]).filter(Boolean)];
  for(const tool of [...new Set(tools)]){
    const fn=TOOL_LOG[tool];if(!fn)continue;
    for(const ln of fn(t))addLog(ln,M.s1);
  }
}

function dedupe(a){return[...new Set(a.filter(Boolean))];}

function servicesFor(term){
  if(!term.ports||!term.ports.length)term.ports=[...(CTRL_SVCS[term.control]||[])];
  return term.ports;
}

function requiredTools(term,mode='balanced'){
  const ctrl=term.control||'doors';
  let req=mode==='ntlm'?['wifi_scan','capture_handshake','force_auth']:['wifi_scan','capture_handshake','crack_password'];
  if(ctrl==='gates'||ctrl==='dungeon')req.push('door_override');
  if(ctrl==='locks'||ctrl==='security')req.push('circuit_bypass');
  if(ctrl==='loot')req.push('loot_decrypt');
  if(ctrl==='dungeon')req.push('root_shell');
  if(ctrl==='cameras')req.push('credential_dump','camera_blind');
  else if(ctrl==='alarms')req.push('signal_spoof','process_spoof');
  else if(ctrl==='comm')req.push('pivot_relay','arp_poison');
  else if(ctrl==='vault')req.push('loot_decrypt','pass_the_hash');
  else if(ctrl==='power')req.push('circuit_bypass','exploit_vuln');
  else if(ctrl==='db')req.push('sql_inject','credential_dump');
  else if(ctrl==='auth')req.push('kerberoast','forge_token');
  else if(ctrl==='scada')req.push('circuit_bypass','exploit_vuln','shellcode_exec');
  else if(ctrl==='radio')req.push('arp_poison','signal_spoof','dns_exfil');
  else if(ctrl==='firmware')req.push('flash_firmware','exploit_vuln');
  else if(ctrl==='backup')req.push('pass_the_ticket','loot_decrypt');
  else if(ctrl==='cloud')req.push('remote_exec','credential_dump');
  else if(ctrl==='registry')req.push('lolbin_exec','token_impersonate');
  else if(ctrl==='webshell')req.push('exploit_vuln','persist_boot','obfuscate');
  else if(ctrl==='vpn')req.push('pivot_relay','force_auth','icmp_covert');
  else if(ctrl==='container')req.push('shellcode_exec','uac_escape','privilege_escalation');
  if(mode==='stealth')req.push('signal_spoof');
  else if(mode==='bruteforce')req.push('privilege_escalation');
  else if(mode==='exploit')req.push('circuit_bypass','privilege_escalation');
  else if(mode==='pivot')req.push('pivot_relay');
  else if(mode==='evasion')req.push('erase_logs','process_spoof');
  else if(mode==='recon')req.push('port_scan','host_discovery');
  else if(mode==='kerberos')req.push('kerberoast','forge_token');
  else if(mode==='wmi')req.push('wmi_exec');
  else if(mode==='lolbin')req.push('lolbin_exec');
  if((term.tier||1)>=3)req.push('root_shell');
  return dedupe(req);
}

function hasTool(tool){
  if(BUILTIN_TOOLS.has(tool)||G.tools.has(tool))return true;
  if(G.validCreds&&CRED_TOOLS.has(tool))return true;
  const res=TOOL_RES[tool];
  return !!(res&&G.resources[res]&&G.resources[res].size);
}

function toolGaps(term,mode='balanced'){
  return requiredTools(term,mode).filter(t=>!hasTool(t));
}

function resourceGaps(term,mode='balanced'){
  return dedupe(requiredTools(term,mode).map(t=>TOOL_RES[t]).filter(r=>r&&!G.resources[r].size));
}

function moduleGaps(term,mode='balanced'){
  return dedupe(toolGaps(term,mode).map(t=>TOOL_TO_MODULE[t]).filter(Boolean));
}

function hackChance(term,mode){
  const skill=MODE_SKILL[mode]||'exploit';
  const lvl=G.skills[skill]||0;
  const base=CTRL_SKILL[term.control];
  const skillIdx={recon:0,exploit:1,creds:2,lateral:3,persist:4,evasion:5}[skill]||1;
  const req=base?(base[skillIdx]*(1+(term.tier-1)*0.5)+Math.floor(G.level/3)):1;
  const gap=Math.max(0,req-lvl);
  const modeBonus={balanced:0,stealth:-0.08,spoof:0.03,bruteforce:0.08,exploit:0.04,
    pivot:-0.05,evasion:-0.12,recon:0,social:0.08,kerberos:0.15,wmi:0.10,ntlm:0.07,lolbin:0.12}[mode]||0;
  const heatPen=HEAT_HACK[heatLevel()];
  return Math.max(0.05,Math.min(0.95,0.6-gap*0.12+modeBonus+G.firmwareBonus+hackBonus()*0.02-heatPen));
}

function hackSuccess(term,mode){
  return rf()<hackChance(term,mode);
}

function applyTerminalEffect(term){
  const ctrl=term.control;
  if(ctrl==='doors'||ctrl==='locks'){
    let n=0;
    for(const[dk,di] of Object.entries(doors)){if(di.hack_ssid===term.ssid&&di.locked){di.locked=false;di.hack_locked=false;const[dx,dy]=dk.split(',').map(Number);setc(grid,dx,dy,'+');n++;}}
    addLog(`Hacked ${ctrl}: ${n} doors unlocked.`,M.grn);
  } else if(ctrl==='gates'){for(const[dk,di]of Object.entries(doors)){if(di.locked&&!di.hack_locked){di.locked=false;const[dx,dy]=dk.split(',').map(Number);setc(grid,dx,dy,'+');}}addLog('Hacked gates: exit gate servos and ordinary locks opened.',M.grn);}
  else if(ctrl==='loot'){for(let i=0;i<ri(2,4);i++){const[fx,fy]=freeNear(G.px,G.py);const it={...randLoot(G.level),id:`it${++_seq}`,x:fx,y:fy};items[it.id]=it;setc(grid,fx,fy,it.char);}addLog('Hacked loot: items spawned nearby.',M.grn);}
  else if(ctrl==='security'){G.heat=clampHeat(G.heat-1.0);for(const e of Object.values(entities))if(e.hostile&&Math.abs(e.x-G.px)+Math.abs(e.y-G.py)<=10){e.alerted=false;e.alertTimer=0;}addLog('Hacked security: heat -1.0, guards de-alerted.',M.grn);}
  else if(ctrl==='cameras'){G.heat=clampHeat(G.heat-1.5);for(const e of Object.values(entities))e.alerted=false;addLog('Hacked cameras: heat -1.5, all guards de-alerted.',M.grn);}
  else if(ctrl==='alarms'){G.heat=clampHeat(G.heat-2.0);for(const e of Object.values(entities))e.alerted=false;addLog('Hacked alarms: heat -2.0, level de-alerted.',M.grn);}
  else if(ctrl==='backup'){G.hp=G.maxHp;addLog('Hacked backup: HP fully restored.',M.grn);}
  else if(ctrl==='auth'){G.validCreds=true;addLog('Hacked auth: valid_credentials gained.',M.grn);}
  else if(ctrl==='firmware'){G.firmwareBonus=Math.min(0.20,G.firmwareBonus+0.05);addLog(`Hacked firmware: hack bonus +5% (total ${Math.round(G.firmwareBonus*100)}%).`,M.grn);}
  else if(ctrl==='vault'){for(let i=0;i<3;i++){const[fx,fy]=freeNear(G.px,G.py);const it={...mkGear(rf()<0.5,G.level+2),id:`it${++_seq}`,x:fx,y:fy};items[it.id]=it;setc(grid,fx,fy,it.char);}addLog('Hacked vault: high-value loot spawned.',M.grn);}
  else if(ctrl==='cloud'){for(let i=0;i<4;i++){const[fx,fy]=freeNear(G.px,G.py);const it={...mkGear(rf()<0.5,G.level+3),id:`it${++_seq}`,x:fx,y:fy};items[it.id]=it;setc(grid,fx,fy,it.char);}addLog('Hacked cloud: legendary loot spawned.',M.grn);}
  else if(ctrl==='power'){G.activeEffects.push({name:'grid destabilized',type:'patrol_freeze',duration:25,value:1});addLog('Hacked power: grid destabilized, patrols freeze for 25 turns.',M.grn);}
  else if(ctrl==='registry'){G.heat=clampHeat(G.heat-1.0);for(const e of Object.values(entities))e.sight=Math.max(3,e.sight-3);addLog('Hacked registry: heat -1.0, guard sight -3.',M.grn);}
  else if(ctrl==='vpn'){revealCurrentLevel();addLog('Hacked VPN: map revealed, all doors forced open.',M.grn);}
  else if(ctrl==='container'){const cells=rooms.flatMap(r=>floorCells(grid,r)).filter(([x,y])=>!entityAt(x,y));if(cells.length)[G.px,G.py]=ch(cells);computeVisible(visionRadius());addLog('Hacked container: teleported to random location.',M.mau);}
  else if(ctrl==='scada'){for(const e of Object.values(entities))e.alerted=false;addLog('Hacked SCADA: all controls unlocked.',M.grn);}
  else if(ctrl==='radio'){addLog('Hacked radio: free module spawned.',M.grn);const mn=ch(Object.keys(MODULE_TO_TOOL));if(!G.modules.has(mn)){G.modules.add(mn);G.tools.add(MODULE_TO_TOOL[mn]);addLog(`Gained module: ${mn}`,M.pch);}}
  else if(ctrl==='comm'){for(const e of Object.values(entities))if(e.hostile)e.alerted=false;addLog('Hacked comm: guard coordination jammed; patrols de-alerted.',M.grn);}
  else if(ctrl==='db'){addClue(`DB dump from ${term.ssid}`,'db');addLog('Hacked DB: intel gathered.',M.grn);}
  else if(ctrl==='webshell'){addLog('Hacked webshell: dropped web access token.',M.grn);}
  else if(ctrl==='dungeon'){revealCurrentLevel();addLog('Hacked dungeon: map fully revealed.',M.grn);}
  else{addLog(`Hacked ${ctrl}.`,M.grn);}
  releaseLinkedHackChests(term);
  // Provide resource if terminal grants one
  const res=TERM_RES[ctrl];
  if(res){G.resources[res].add(term.ssid);addLog(`Resource [${res}] available from ${term.ssid}.`,M.blu);}
  G.stats.terminals_rooted++;
  // Skill XP
  const skillName=MODE_SKILL[G.hackMode]||'exploit';
  addSkillXP(skillName,1);
}

function freeNear(cx,cy){
  for(let r=1;r<=5;r++){
    const cells=[];
    for(let y=cy-r;y<=cy+r;y++)for(let x=cx-r;x<=cx+r;x++)if(getc(grid,x,y)==='.'&&!entityAt(x,y))cells.push([x,y]);
    if(cells.length)return ch(cells);
  }
  return[cx,cy];
}

function execHack(mode,skipToolCheck=false){
  const term=adjTerminal();
  if(!term){addLog('No terminal adjacent.',M.red);return false;}
  if(term.hacked&&mode!=='evasion'){addLog('Already rooted. Try "botnet" or "pivot".',M.yel);return false;}
  if(mode==='recon'){
    const base=CTRL_SKILL[term.control]||[0,0,0,0,0,0];
    addLog(`[RECON] ${term.ssid} (tier${term.tier}):`,M.blu);
    if(!term.portscanned){
      addLog('  No service data. Run portscan first.',M.yel);
    } else {
      servicesFor(specials[term.key]);
      addLog(`  Balanced chance: ${Math.round(hackChance(term,'balanced')*100)}%`,M.blu);
      if(term.vulnscanned){
        addLog(`  Tools: ${requiredTools(term,'balanced').join(', ')}`,M.sub);
        const gaps=toolGaps(term,'balanced'),mods=moduleGaps(term,'balanced'),res=resourceGaps(term,'balanced');
        addLog(`  Missing tools: ${gaps.length?gaps.join(', '):'none'}`,gaps.length?M.yel:M.grn);
        if(mods.length)addLog(`  Modules needed: ${mods.join(', ')}`,M.pch);
        if(res.length)addLog(`  Resources offline: ${res.join(', ')}`,M.yel);
      } else {
        addLog('  Run vulnscan to identify CVEs and required modules.',M.yel);
      }
      const snames=['recon','exploit','creds','lateral','persist','evasion'];
      for(let i=0;i<6;i++)addLog(`  ${snames[i]}: need ${Math.ceil(base[i]*(1+(term.tier-1)*0.5))}  have ${G.skills[snames[i]]}`,base[i]*(1+(term.tier-1)*0.5)<=G.skills[snames[i]]?M.grn:M.yel);
    }
    return false;
  }
  if(!skipToolCheck){
    const gaps=mode==='social'?[]:toolGaps(term,mode);
    if(gaps.length){
      if(!term.vulnscanned){
        addLog(`Hack failed — unknown tool gaps. Run portscan + vulnscan first.`,M.yel);
      } else {
        addLog(`Missing tools for ${mode}: ${gaps.join(', ')}`,M.red);
        const mods=moduleGaps(term,mode);
        if(mods.length)addLog(`Modules needed: ${mods.join(', ')}`,M.pch);
      }
      return false;
    }
  }
  const hd=MODE_HEAT[mode]||0;G.heat=clampHeat(G.heat+hd);
  G.hackMode=mode;
  if(hackSuccess(term,mode)){
    addLog(`HACK SUCCESS [${mode}] — ${term.ssid} ROOTED.`,M.grn);
    specials[term.key].hacked=true;
    applyTerminalEffect({...term,...specials[term.key]});
    if(['kerberos','ntlm'].includes(mode)){G.validCreds=true;addLog('Session flag set: valid_credentials.',M.blu);}
    if(mode==='evasion'){specials[term.key].hacked=false;addLog('Evasion: logs purged, terminal re-hackable.',M.sky);}
    if(mode==='pivot'){G.stats.pivots++;}
    if(mode==='lolbin'||mode==='evasion'){G.heat=clampHeat(G.heat+hd);}// already applied once
    return true;
  } else {
    addLog(`HACK FAILED [${mode}] — ${term.ssid} resisted.`,M.red);
    G.heat=clampHeat(G.heat+0.2);
    if(term.honeypot){G.heat=clampHeat(G.heat+1.5);addLog('[HONEYPOT TRIGGERED] Heat +1.5.',M.red);G.stats.honeypots_tripped++;}
    adjustRep(-1,'failed hack');
    return true;
  }
}

function openHackSetup(mode){
  const term=adjTerminal();
  if(!term){addLog('No terminal adjacent.',M.red);return;}
  if(term.hacked&&mode!=='evasion'){addLog('Already rooted. Try "botnet" or "pivot".',M.yel);return;}
  G.hackTerm=term;G.hackMode=mode;G.hackLoadout=[];G.hackCursor=0;
  G.overlay='module_select';render();
}

function execHackFromLoadout(){
  const term=G.hackTerm;if(!term){addLog('No terminal.',M.red);return false;}
  const mode=G.hackMode;const loadout=G.hackLoadout;
  // Build tool set from loadout (plus builtins and resource/cred tools)
  const lt=new Set([...BUILTIN_TOOLS,...loadout.map(m=>MODULE_TO_TOOL[m]).filter(Boolean)]);
  for(const[tool,res] of Object.entries(TOOL_RES)){if(G.resources[res]&&G.resources[res].size)lt.add(tool);}
  if(G.validCreds)for(const t of CRED_TOOLS)lt.add(t);
  const req=requiredTools(term,mode);
  const gaps=mode==='social'?[]:req.filter(t=>!lt.has(t));
  if(gaps.length){
    addLog(`Loadout missing: ${gaps.join(', ')}`,M.red);
    const mods=gaps.map(t=>TOOL_TO_MODULE[t]).filter(Boolean);
    if(mods.length)addLog(`Add to loadout: ${mods.join(', ')}`,M.pch);
    return false;
  }
  if(loadout.length)addLog(`Chain: ${loadout.join(' → ')}`,M.sub);
  emitHackLogs(term,loadout);
  return execHack(mode,true); // loadout gap check already done above
}

