*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;height:100%;background:#1e1e2e;overflow:hidden;position:relative}
#c{display:block;image-rendering:pixelated;image-rendering:crisp-edges;position:absolute}
#inp{position:fixed;bottom:0;left:0;width:100%;background:#11111b;border-top:1px solid #45475a;padding:4px 8px;color:#cdd6f4;font:14px 'Courier New',monospace;display:none;outline:none}
#mode-link{position:fixed;top:2px;right:4px;z-index:200;padding:2px 7px;background:rgba(17,17,27,0.88);border:1px solid #45475a;border-radius:3px;font:10px 'Courier New',monospace}
#mode-link a{color:#89b4fa;text-decoration:none}
#touch-ui{position:fixed;bottom:0;left:0;width:100%;z-index:150;background:rgba(17,17,27,0.97);border-top:1px solid #585b70;padding:4px;display:none;gap:4px;align-items:flex-start}
#tui-dp{display:grid;grid-template-columns:repeat(3,44px);grid-template-rows:repeat(3,44px);gap:2px;flex-shrink:0}
#tui-dp button{width:44px;height:44px;font-size:22px;background:#45475a;border:1px solid #6c7086;color:#cdd6f4;border-radius:5px;cursor:pointer;touch-action:manipulation;-webkit-user-select:none;user-select:none}
#tui-dp .dp0{visibility:hidden;pointer-events:none}
#tui-dp button:active{background:#585b70}
#tui-btns{display:grid;grid-template-columns:repeat(5,1fr);gap:2px;flex:1}
#tui-btns button{height:27px;font-size:9px;background:#313244;border:1px solid #45475a;color:#cdd6f4;border-radius:3px;cursor:pointer;touch-action:manipulation;-webkit-user-select:none;user-select:none;padding:0 1px;white-space:nowrap;overflow:hidden}
#tui-btns button:active{filter:brightness(1.4)}
#tui-btns .bh{background:#1a2d45;border-color:#89b4fa;color:#89b4fa}
#tui-btns .bm{background:#1a2e1e;border-color:#a6e3a1;color:#a6e3a1}
#tui-btns .bo{background:#2e1c3a;border-color:#cba6f7;color:#cba6f7}
#tui-btns .bd{background:#2a271a;border-color:#f9e2af;color:#f9e2af}
#ctx-bar{position:fixed;top:0;left:0;width:100%;z-index:160;background:rgba(17,17,27,0.97);border-bottom:1px solid #45475a;padding:3px 4px;display:none;flex-wrap:wrap;gap:3px;align-items:center}
#ctx-bar button{height:26px;padding:0 7px;font:10px 'Courier New',monospace;border-radius:3px;cursor:pointer;touch-action:manipulation;-webkit-user-select:none;user-select:none;white-space:nowrap}
#ctx-bar button:active{filter:brightness(1.5)}
#ctx-bar .cb{background:#1a2d45;border:1px solid #89b4fa;color:#89b4fa}
#ctx-bar .cg{background:#1a2e1e;border:1px solid #a6e3a1;color:#a6e3a1}
#ctx-bar .cy{background:#2a271a;border:1px solid #f9e2af;color:#f9e2af}
#ctx-bar .cp{background:#2e1c3a;border:1px solid #cba6f7;color:#cba6f7}
#ctx-bar .cr{background:#2e1c1c;border:1px solid #f38ba8;color:#f38ba8}
#ctx-bar .cd{background:#313244;border:1px solid #45475a;color:#6c7086}
</style>
</head>
