function dimColor(hex){
  const r=parseInt(hex.slice(1,3),16),g2=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return`#${Math.floor(r*0.35).toString(16).padStart(2,'0')}${Math.floor(g2*0.35).toString(16).padStart(2,'0')}${Math.floor(b*0.35).toString(16).padStart(2,'0')}`;
}
const _dimCache={};
function dim(hex){if(!_dimCache[hex])_dimCache[hex]=dimColor(hex);return _dimCache[hex];}

function drawGameView(){
  const camX=Math.max(0,Math.min(WW-VW,G.px-Math.floor(VW/2)));
  const camY=Math.max(0,Math.min(WH-VH,G.py-Math.floor(VH/2)));
  G._camX=camX;G._camY=camY;
  for(let sy=0;sy<VH;sy++){
    for(let sx=0;sx<VW;sx++){
      const wx=camX+sx,wy=camY+sy;
      const key=`${wx},${wy}`;
      const px2=sx*CW,py2=sy*CH;
      const isSeen=seen.has(key),isVis=visible.has(key);
      ctx.fillStyle=M.base;ctx.fillRect(px2,py2,CW,CH);
      if(!isSeen)continue;
      let c=grid[wy][wx];
      // Show entity if visible
      if(isVis){const ent=entityAt(wx,wy);if(ent)c=ent.char;}
      // Show player
      if(isVis&&wx===G.px&&wy===G.py)c='@';
      const fg=FG[c]||M.txt;
      ctx.fillStyle=isVis?fg:dim(fg);
      ctx.fillText(c,px2,py2);
    }
  }
}

function drawSidebar(){
  if(IS_PORTRAIT)return;
  const ox=VW*CW;
  ctx.font=`${SCH}px 'Courier New',monospace`;
  ctx.fillStyle=M.mantle;ctx.fillRect(ox,0,SW*CW,CAN_H);
  // Border
  ctx.fillStyle=M.s1;
  for(let y=0;y<Math.ceil(CAN_H/SCH)+1;y++){ctx.fillText('│',ox,y*SCH);}
  let row=0;
  function sl(text,color=M.txt,x=1){ctx.fillStyle=color;ctx.fillText(text.slice(0,SW-1),ox+x*SCW,row++*SCH);}
  sl('══ ARTHACK ══',M.lav);sl('');
  const hlvl=heatLevel();
  sl(`HEAT: ${G.heat.toFixed(1)} [${HEAT_LABELS[hlvl]}]`,HEAT_COLORS[hlvl]);
  // Heat bar
  const barW=SW-4,filled=Math.round(G.heat/5*barW);
  ctx.fillStyle=M.s0;ctx.fillRect(ox+2*SCW,row*SCH,barW*SCW,SCH-2);
  ctx.fillStyle=HEAT_COLORS[hlvl];ctx.fillRect(ox+2*SCW,row*SCH,filled*SCW,SCH-2);
  row++;sl('');
  sl(`Sight +${HEAT_SIGHT[hlvl]} Hack -${Math.round(HEAT_HACK[hlvl]*100)}%`,M.sub);
  if(hlvl>=3)sl(`Reinforce: ${HEAT_INTVL[hlvl]}t`,M.red);
