function hackModeFromText(text){
  const low=String(text||'').toLowerCase();
  const exact=low.split(/\s+/).find(w=>MODE_SKILL[w]);
  if(exact)return exact;
  if(/social|phish|engineer|pretex/.test(low))return'social';
  if(/kerberos|kerberoast|golden|ticket|tgt/.test(low))return'kerberos';
  if(/wmi|windows management|cim/.test(low))return'wmi';
  if(/ntlm|relay|responder|coerce/.test(low))return'ntlm';
  if(/lolbin|certutil|mshta|living/.test(low))return'lolbin';
  if(/brute|force/.test(low))return'bruteforce';
  if(/stealth/.test(low))return'stealth';
  if(/spoof/.test(low))return'spoof';
  if(/pivot|tunnel|lateral/.test(low))return'pivot';
  if(/evasion|evade|wipe|obfus|clear/.test(low))return'evasion';
  if(/recon|scan|enum/.test(low))return'recon';
  if(/exploit|bypass|logic|cve/.test(low))return'exploit';
  return'balanced';
}

function processCmd(cmd){
  cmd=cmd.trim();if(!cmd)return;
  const parts=cmd.split(/\s+/);
  const c=parts[0].toLowerCase();
  const low=cmd.toLowerCase();
  if(low==='help hack'||low==='hack help'||low==='i am confused'||low==='confused'){
    emitHackingInstructions();return;
  }
  if(low==='toolkit'||low==='show toolkit'||low==='open toolkit'){
    G.overlay='toolkit';return;
  }
  if(low==='show modules'||low==='modules'||low==='list modules'){
    addLog(`Modules (${G.modules.size}): ${[...G.modules].join(', ')}`,M.pch);
    addLog(`Tools (${G.tools.size}): ${[...G.tools].join(', ')}`,M.grn);
    return;
  }
  if(low==='help'||low==='?'){G.overlay='help';return;}
  if(low==='commands'||low==='command list'||low==='controls'){G.overlay='commands';return;}
  if(low==='inventory'||low==='inv'||low==='bag'){G.overlay='inventory';G.invCursor=0;return;}
  if(low==='craft'||low==='crafting'){G.overlay='craft';G.craftCursor=0;G.craftScroll=0;G.craftConfirm=null;return;}
  if(low==='skills'||low==='skill'){G.overlay='skills';return;}
  if(low==='map'||low==='minimap'){G.showMinimap=!G.showMinimap;return;}
  if(low==='journal'||low==='notes'){G.overlay='journal';return;}
  if(low==='rest'||low==='wait'){addLog('You rest and listen to the castle.',M.sub);endTurn();return;}
  if(low==='confront'||low==='fight'||low==='talk'){doConfront();return;}
  if(low==='stealth'||low==='sneak'){G.stealthMode=!G.stealthMode;addLog(G.stealthMode?'Stealth ON.':'Stealth OFF.',M.sky);return;}
  if(low==='shoot'||low==='fire'){
    if(!G.shootMode&&!G.equipped.weapon?.range){addLog('Equip a bow, crossbow, or slingshot to shoot.',M.red);return;}
    G.shootMode=!G.shootMode;addLog(G.shootMode?'Shoot mode ON.':'Shoot mode OFF.',M.red);return;
  }
  if(c==='scan'){
    const ts=termWithin(18);
    if(!ts.length){addLog('No terminals in range.',M.sub);return;}
    addLog(`Scan: ${ts.length} terminal(s) detected:`,M.blu);
    for(const t of ts){
      const dist=Math.abs(t.x-G.px)+Math.abs(t.y-G.py);
      const type=G.archetype==='netrunner'&&dist<=5?`[${t.control}]`:'[?]';
      addLog(`  ${t.ssid}  ${type} tier${t.tier} ${t.hacked?'ROOTED':'locked'} dist:${dist}`,M.sub);
      if(t.ip)addLog(`    ${t.ip}  ${t.mac}  ${t.hostname}`,M.s1);
    }
  } else if(c==='portscan'||c==='ps'){
    const t=adjTerminal();if(!t){addLog('No adjacent terminal.',M.red);return;}
    servicesFor(specials[t.key]);specials[t.key].portscanned=true;
    const svcs=specials[t.key].ports;
    addLog(`Portscan ${t.hostname||t.ssid} (${t.ip||'?'}):`,M.blu);
    if(t.mac)addLog(`  MAC: ${t.mac}  vendor: ${ch(FAKE_VEN)}`,M.s1);
    for(const[proto,port] of svcs)addLog(`  ${proto}/${port}  OPEN`,M.sub);
    addLog('  Run vulnscan to map CVEs and required tools.',M.s1);
    G.skills.recon=Math.max(G.skills.recon,1);
  } else if(c==='vulnscan'||c==='vs'){
    const t=adjTerminal();if(!t){addLog('No adjacent terminal.',M.red);return;}
    if(!t.portscanned){addLog('No port data — run portscan first.',M.yel);return;}
    servicesFor(specials[t.key]);specials[t.key].vulnscanned=true;
    const svcs=specials[t.key].ports;
    addLog(`Vulnscan ${t.ssid}:`,M.blu);
    for(const[proto,port] of svcs){const v=SVC_VULNS[`${proto}:${port}`];if(v)addLog(`  ${proto}/${port}: ${v[0].slice(0,44)} -> ${v[1]} ${hasTool(v[1])?'OK':'MISS'}`,hasTool(v[1])?M.grn:M.yel);}
    if(t.honeypot)addLog('  HONEYPOT indicators present. Expect heat spike on failure.',M.red);
    const mode=parts[1]||'balanced';
    const gaps=toolGaps(t,mode),mods=moduleGaps(t,mode),res=resourceGaps(t,mode);
    addLog(`  ${mode} chance: ${Math.round(hackChance(t,mode)*100)}%`,M.blu);
    addLog(`  Missing tools: ${gaps.length?gaps.join(', '):'none'}`,gaps.length?M.yel:M.grn);
    if(mods.length)addLog(`  Modules needed: ${mods.join(', ')}`,M.pch);
    if(res.length)addLog(`  Resources offline: ${res.join(', ')}`,M.yel);
    G.skills.recon=(G.skills.recon||0)+1;
  } else if(c==='hack'){
    const mode=hackModeFromText(cmd);
    if(!MODE_SKILL[mode]){addLog(`Unknown mode: ${mode}. Modes: ${Object.keys(MODE_SKILL).join(', ')}`,M.red);return;}
    openHackSetup(mode);
  } else if(c==='x'){
    openHackSetup('balanced');
  } else if(c==='botnet'||low==='bot'||low==='implant'||low==='install botnet'){
    const t=adjTerminal();if(!t){addLog('No adjacent terminal.',M.red);return;}
    if(!t.hacked){addLog('Must root terminal first.',M.red);return;}
    const hasPersist=hasTool('persist_cron')||hasTool('persist_boot');
    const hasC2=hasTool('dns_exfil')||hasTool('icmp_covert');
    if(!hasPersist||!hasC2){addLog('Need persistence + C2 tools (persist_cron/persist_boot and dns_exfil/icmp_covert).',M.red);return;}
    if(specials[t.key].botnet){addLog('C2 node already installed here.',M.yel);return;}
    specials[t.key].botnet=true;
    const res=TERM_RES[t.control];if(res)G.resources[res].add(t.ssid);
    if(!G.stats.botnets)G.stats.botnets=0;G.stats.botnets++;
    G.skills.persist=(G.skills.persist||0)+1;
    addLog(`C2 node installed on ${t.ssid}. Resource [${res||'none'}] ONLINE.`,M.grn);endTurn();
  } else if(c==='pivot'||low==='tunnel'||low==='pivot hack'||low==='lateral'){
    const t=adjTerminal();if(!t||!t.botnet){addLog('Need adjacent C2 node.',M.red);return;}
    const targets=termWithin(8).filter(x=>x.key!==t.key&&!x.hacked);
    if(!targets.length){addLog('No hackable terminals within pivot range.',M.red);return;}
    const target=targets[0];
    const gaps=toolGaps(target,'pivot');
    if(gaps.length){addLog(`Pivot missing tools: ${gaps.join(', ')}`,M.red);return;}
    G.heat=clampHeat(G.heat+0.1);
    if(hackSuccess(target,'pivot')){specials[target.key].hacked=true;applyTerminalEffect({...target,...specials[target.key]});G.stats.pivots++;addLog(`Pivot hack success: ${target.ssid} ROOTED.`,M.grn);}
    else{addLog('Pivot hack failed.',M.red);}
    endTurn();
  } else if(c==='practice'){
    const sk=parts[1]||'exploit';const t=adjTerminal();
    if(!t||!t.hacked){addLog('Need rooted adjacent terminal.',M.red);return;}
    if(!G.skills.hasOwnProperty(sk)){addLog(`Unknown skill: ${sk}`,M.red);return;}
    G.skills[sk]=(G.skills[sk]||0)+1;
    addLog(`Practiced ${sk}. Now Lv${G.skills[sk]}.`,M.grn);
    if(rf()<0.1){const mn=ch(Object.keys(MODULE_TO_TOOL));G.inventory.push(mkItem({char:'$',name:`${mn} module`,kind:'module',module:mn,weight:0.2,valueCp:200}));addLog(`Bonus module found: ${mn}`,M.pch);}
    endTurn();
  } else if(c==='clearlogs'||low==='clear logs'||low==='wipe logs'||low==='wipe'||low==='cover tracks'){
    const t=adjTerminal();if(!t||!t.hacked){addLog('Need rooted adjacent terminal.',M.red);return;}
    if(!hasTool('erase_logs')){addLog('Need log_wiper / erase_logs to clear logs.',M.red);return;}
    G.heat=clampHeat(G.heat-1.0);G.stats.logs_cleared++;adjustRep(1,'clean operator');
    if(activeResponder()&&heatLevel()<2)despawnResponder('Trail goes cold — IR loses your implants.');
    addLog(`Logs cleared on ${t.ssid}. Heat -1.0.`,M.grn);endTurn();
  } else if(c==='equip'){doEquip(parts.slice(1).join(' '));endTurn();}
  else if(c==='unequip'){doUnequip(parts[1]||'');endTurn();}
  else if(c==='drink'||c==='use'){doDrink(parts.slice(1).join(' '));endTurn();}
  else if(c==='drop'){
    if(parts.length===1){
      const sp=specials[`${G.px},${G.py}`];
      if(!sp||sp.kind!=='trapdoor'){addLog('Usage: drop <item name>, or stand on a trapdoor to drop down.',M.red);return;}
      transitionBySpecial(sp);endTurn();
    } else if(doDrop(parts.slice(1).join(' ')))endTurn();
  }
  else if(c==='move'){
    const rest=parts.slice(1).join(' ');
    const m=rest.match(/\s+to\s+(backpack|inventory|bag)\s*$/i);
    const target=m?(m[1].toLowerCase()==='backpack'?'backpack':'bag'):null;
    const name=m?rest.slice(0,m.index).trim():rest;
    if(doMoveItem(name,target))endTurn();
  }
  else if(c==='buy'){doBuy(parts.slice(1).join(' '));endTurn();}
  else if(c==='sell'){doSell(parts.slice(1).join(' '));endTurn();}
  else if(c==='contracts'||c==='contract'||c==='jobs'||c==='objectives'){
    G.overlay='journal';
  }
  else if(c==='log'||c==='logs'){openLogOverlay();}
  else if(c==='summary'||c==='stats'){G.overlay='summary';}
  else if(c==='inspect'){
    const needle=parts.slice(1).join(' ');
    const it=findHeldItem(needle)||Object.values(items).find(x=>x.name.toLowerCase().includes(needle.toLowerCase()));
    if(it)inspectItem(it);else addLog('Nothing matching that name to inspect.',M.red);
  }
  else if(c==='look'||c==='examine'){lookAround();}
  else if(c==='search'){searchHere();}
  else if(c==='autoloot'||c==='loot'){autoLootRoom();}
  else if(c==='shop'){if(currentShop()){G.overlay='shop';G.shopCursor=0;G.shopScroll=0;}else addLog('No quartermaster nearby.',M.red);}
  else if(c==='descend'||c==='ascend'){
    const sp=specials[`${G.px},${G.py}`];
    if(!sp||!(sp.kind==='stairs_up'||sp.kind==='stairs_down')){addLog('Not on stairs.',M.red);return;}
    const tl=sp.targetLevel;if(tl<0||tl>=NUM_LEVELS){addLog('No level there.',M.red);return;}
    transitionBySpecial(sp);endTurn();
  } else if(c==='difficulty'){
    const d=parts[1]?.toLowerCase();
    if(!['easy','normal','hard','nightmare'].includes(d)){addLog('Usage: difficulty easy|normal|hard|nightmare',M.red);return;}
    G.difficulty=d;addLog(`Difficulty set to ${d}.`,M.yel);
  } else if(c==='too'&&parts[1]==='hard'){
    const order=['easy','normal','hard','nightmare'];const i=order.indexOf(G.difficulty);if(i>0){G.difficulty=order[i-1];addLog(`Difficulty lowered to ${G.difficulty}.`,M.grn);}
  } else if(c==='too'&&parts[1]==='easy'){
    const order=['easy','normal','hard','nightmare'];const i=order.indexOf(G.difficulty);if(i<3){G.difficulty=order[i+1];addLog(`Difficulty raised to ${G.difficulty}.`,M.yel);}
  } else{addLog(`Unknown command: ${c}. Press c for command list.`,M.red);}
}

// ── Input handling ────────────────────────────────────────────
const inp=document.getElementById('inp');

document.addEventListener('keydown',e=>{
  if(G.overlay==='archetype'){handleArchKey(e);return;}
  if(G.overlay==='difficulty'){handleDifficultyKey(e);return;}
  if(G.overlay==='win'||G.overlay==='dead'||G.overlay==='quit'||G.overlay==='summary'){
    if(G.overlay==='dead')restartGame();
    else G.overlay=null;
    render();return;
  }
  if(G.cmdMode){if(e.key==='Enter'){inp.style.display='none';G.cmdMode=false;processCmd(G.cmdBuf);G.cmdBuf='';render();}
  else if(e.key==='Escape'){inp.style.display='none';G.cmdMode=false;G.cmdBuf='';}
  return;}
  if(G.overlay){handleOverlayKey(e);render();return;}
  const k=e.key;
  if(k==='t'||k==='T'||k==='/'){G.cmdMode=true;G.cmdBuf='';inp.style.display='block';inp.focus();setTimeout(()=>{inp.value='';},0);return;}
  if(k==='m'||k==='M'){G.showMinimap=!G.showMinimap;render();return;}
  if(k==='i'||k==='I'){G.overlay='inventory';G.invCursor=0;render();return;}
  if(k==='g'||k==='G'){G.overlay='craft';G.craftCursor=0;G.craftScroll=0;G.craftConfirm=null;render();return;}
  if(k==='p'||k==='P'){if(currentShop()){G.overlay='shop';G.shopCursor=0;G.shopScroll=0;}else G.overlay='toolkit';render();return;}
  if(k==='o'||k==='O'){openLogOverlay();render();return;}
  if(k==='='){G.overlay='summary';render();return;}
  if(k==='u'||k==='U'){G.overlay='skills';render();return;}
  if(k==='n'||k==='N'){G.overlay='journal';render();return;}
  if(k==='c'){G.overlay='commands';render();return;}
  if(k==='?'){G.overlay='help';render();return;}
  if(k==='l'||k==='L'){lookAround();render();return;}
  if(k==='e'||k==='E'||k===' '){searchHere();render();return;}
  if(k==='A'){autoLootRoom();render();return;}
  if(k==='v'||k==='V'){G.stealthMode=!G.stealthMode;addLog(G.stealthMode?'Stealth ON.':'Stealth OFF.',M.sky);render();return;}
  if(k==='z'||k==='Z'){
    if(!G.shootMode&&!G.equipped.weapon?.range){addLog('Equip a bow, crossbow, or slingshot to shoot.',M.red);render();return;}
    G.shootMode=!G.shootMode;addLog(G.shootMode?'Shoot mode ON.':'Shoot mode OFF.',M.red);render();return;
  }
  if(k==='f'||k==='F'){doConfront();render();return;}
  if(k==='x'||k==='X'){openHackSetup('balanced');render();return;}
  if(k==='-'){processCmd('clearlogs');render();return;}
  if(k==='r'||k==='R'){addLog('You rest and listen to the castle.',M.sub);endTurn();render();return;}
  if(k==='q'||k==='Q'){if(confirm('Quit ARTHACK?')){G.overlay='quit';render();}return;}
  e.preventDefault();
  let dx=0,dy=0;
  if(k==='ArrowUp'||k==='w'||k==='W'||k==='k')dy=-1;
  else if(k==='ArrowDown'||k==='s'||k==='S'||k==='j')dy=1;
  else if(k==='ArrowLeft'||k==='a'||k==='A'||k==='h')dx=-1;
  else if(k==='ArrowRight'||k==='d'||k==='D')dx=1;
  else if(k==='y'){{dx=-1;dy=-1;}}else if(k==='u'){dx=1;dy=-1;}
  else if(k==='b'){dx=-1;dy=1;}else if(k==='n'){dx=1;dy=1;}
  if(dx!==0||dy!==0){if(G.shootMode)doRangedShot(dx,dy);else tryMove(dx,dy);}
  render();
});

inp.addEventListener('keydown',e=>{
  if(e.key==='Enter'){const v=inp.value;inp.style.display='none';inp.blur();G.cmdMode=false;processCmd(v);G.cmdBuf='';render();}
  else if(e.key==='Escape'){inp.style.display='none';inp.blur();G.cmdMode=false;G.cmdBuf='';}
  else{G.cmdBuf=inp.value;}
  e.stopPropagation();
});

function handleArchKey(e){
  const order=['infiltrator','combat_specialist','netrunner'];
  if(!G._archCursor)G._archCursor=0;
  if(e.key==='ArrowUp'||e.key==='w'||e.key==='k')G._archCursor=(G._archCursor+2)%3;
  else if(e.key==='ArrowDown'||e.key==='s'||e.key==='j')G._archCursor=(G._archCursor+1)%3;
  else if(e.key==='1')G._archCursor=0;else if(e.key==='2')G._archCursor=1;else if(e.key==='3')G._archCursor=2;
  else if(e.key==='Enter'||e.key===' '){
    G.archetype=order[G._archCursor];applyArchetype();
    G.overlay='difficulty';G._diffCursor=1;render();return;
  }
  render();
}

function startRun(){
  G.overlay=null;
  generateDungeon();generateContracts();
  if(BONUS)applyBonus();
  computeVisible(visionRadius());render();
}

function handleDifficultyKey(e){
  const order=['easy','normal','hard','nightmare'];
  if(G._diffCursor===undefined)G._diffCursor=1;
  if(e.key==='ArrowUp'||e.key==='w'||e.key==='k')G._diffCursor=(G._diffCursor+3)%4;
  else if(e.key==='ArrowDown'||e.key==='s'||e.key==='j')G._diffCursor=(G._diffCursor+1)%4;
  else if(['1','2','3','4'].includes(e.key))G._diffCursor=Number(e.key)-1;
  else if(e.key==='Enter'||e.key===' '){
    G.difficulty=order[G._diffCursor];
    addLog(`Difficulty: ${G.difficulty}.`,M.yel);
    startRun();return;
  }
  render();
}

function handleOverlayKey(e){
  if(G.overlay==='craft'&&G.craftConfirm&&(e.key==='Escape'||e.key==='q'||e.key==='n'||e.key==='N')){
    G.craftConfirm=null;
    return;
  }
  if(e.key==='Escape'||e.key==='q'){G.overlay=null;return;}
  if(G.overlay==='log'){
    const geo=logOverlayGeometry();
    const rows=logOverlayRows(geo.contentW),contentH=geo.contentH,maxScroll=Math.max(0,rows.length-contentH);
    if(e.key==='ArrowUp'||e.key==='k')G.logScroll=Math.max(0,G.logScroll-1);
    else if(e.key==='ArrowDown'||e.key==='j')G.logScroll=Math.min(maxScroll,G.logScroll+1);
    else if(e.key==='PageUp')G.logScroll=Math.max(0,G.logScroll-contentH);
    else if(e.key==='PageDown'||e.key===' ')G.logScroll=Math.min(maxScroll,G.logScroll+contentH);
    else if(e.key==='Home')G.logScroll=0;
    else if(e.key==='End')G.logScroll=maxScroll;
    else G.overlay=null;
  } else if(G.overlay==='inventory'){
    const entries=inventoryEntries();
    if(e.key==='ArrowUp'||e.key==='k')G.invCursor=Math.max(0,G.invCursor-1);
    else if(e.key==='ArrowDown'||e.key==='j')G.invCursor=Math.min(entries.length-1,G.invCursor+1);
    else if(e.key==='1'){G.invView='gear';G.invCursor=0;}
    else if(e.key==='2'){G.invView='jewelry';G.invCursor=0;}
    else if(e.key==='3'){G.invView='modules';G.invCursor=0;}
    else if(e.key==='e'){const ent=entries[G.invCursor];if(ent){if(ent.origin==='equipped')doUnequip(ent.slot);else doEquip(ent.item.name);}}
    else if(e.key==='x'||e.key==='X'){const ent=entries[G.invCursor];if(ent)inspectItem(ent.item);}
    else if(e.key==='m'||e.key==='M'){
      const ent=entries[G.invCursor];
      if(ent&&ent.origin!=='equipped'){if(doMoveItem(ent.item.name))endTurn();}
      else addLog('That item cannot be moved right now.',M.red);
    }
    else if(e.key==='d'||e.key==='D'){
      const ent=entries[G.invCursor];
      if(ent&&ent.origin!=='equipped'){if(doDrop(ent.item.name))endTurn();}
      else addLog('Unequip or stash that item before dropping it.',M.red);
    }
    else if(e.key==='u'||e.key==='U'){
      const ent=entries[G.invCursor];const sel=ent?.item;
      if(ent&&ent.origin==='equipped')addLog('Unequip this item before using it.',M.red);
      else if(sel&&sel.kind==='potion'){doDrink(sel.name);endTurn();}
      else if(sel&&sel.kind==='module'){installModuleItem(sel,'inventory');removeHeldItem(sel);endTurn();}
      else addLog('That item cannot be used from here.',M.sub);
    }
    else if(e.key==='Enter'){
      const ent=entries[G.invCursor];const sel=ent?.item;
      if(sel&&sel.kind==='potion'){doDrink(sel.name);endTurn();}
      else if(sel&&sel.kind==='module'){installModuleItem(sel,'inventory');removeHeldItem(sel);endTurn();}
    }
  } else if(G.overlay==='craft'){
    if(G.craftConfirm){
      if(e.key==='Enter'||e.key==='y'||e.key==='Y'){
        const {item,gem}=G.craftConfirm;
        G.craftConfirm=null;
        if(socketGem(item,gem))endTurn();
      }
      return;
    }
    if(e.key==='s'||e.key==='S'){G.craftView='socket';G.craftCursor=0;G.craftScroll=0;G.gemCursor=0;G.craftConfirm=null;return;}
    else if(e.key==='r'||e.key==='R'){G.craftView='recipes';G.craftCursor=0;G.craftScroll=0;G.craftConfirm=null;return;}
    if(G.craftView==='recipes'){
      const filtered=G.craftFilter?CRAFT_RECIPES.filter(r=>canCraft(r)):CRAFT_RECIPES;
      if(e.key==='ArrowUp'||e.key==='k')G.craftCursor=Math.max(0,G.craftCursor-1);
      else if(e.key==='ArrowDown'||e.key==='j')G.craftCursor=Math.min(Math.max(0,filtered.length-1),G.craftCursor+1);
      else if(e.key==='PageUp')G.craftCursor=Math.max(0,G.craftCursor-20);
      else if(e.key==='PageDown')G.craftCursor=Math.min(Math.max(0,filtered.length-1),G.craftCursor+20);
      else if(e.key==='Home')G.craftCursor=0;
      else if(e.key==='End')G.craftCursor=Math.max(0,filtered.length-1);
      else if(e.key==='f'||e.key==='F'){G.craftFilter=!G.craftFilter;G.craftCursor=0;G.craftScroll=0;}
      else if(e.key==='x'||e.key==='X'){const r=filtered[G.craftCursor];if(r)inspectRecipe(r);}
      else if(e.key==='Enter'){const r=filtered[G.craftCursor];if(r){doCraft(r);endTurn();}}
    } else {
      const items=socketableItems(),gems=availableGems();
      if(e.key==='ArrowUp'||e.key==='k')G.craftCursor=Math.max(0,G.craftCursor-1);
      else if(e.key==='ArrowDown'||e.key==='j')G.craftCursor=Math.min(Math.max(0,items.length-1),G.craftCursor+1);
      else if(e.key==='ArrowLeft'||e.key==='h')G.gemCursor=gems.length?(G.gemCursor||0)+gems.length-1:0;
      else if(e.key==='ArrowRight'||e.key==='l')G.gemCursor=gems.length?(G.gemCursor||0)+1:0;
      else if(e.key==='x'||e.key==='X'){const item=items[G.craftCursor]?.item;if(item)inspectItem(item);}
      else if(e.key==='Enter'){
        const item=items[G.craftCursor]?.item,gem=gems[(G.gemCursor||0)%Math.max(1,gems.length)];
        if(!adjStation('anvil'))addLog('Socketing requires a nearby anvil.',M.red);
        else if(!item||!gem)addLog('Choose gear and a gem first.',M.red);
        else G.craftConfirm={item,gem};
      }
      if(gems.length)G.gemCursor=(G.gemCursor||0)%gems.length;
    }
  } else if(G.overlay==='shop'){
    const shop=currentShop();if(!shop){G.overlay=null;return;}
    const entries=G.shopMode==='stock'?shop.stock:sellEntries();
    if(e.key==='ArrowUp'||e.key==='k')G.shopCursor=Math.max(0,G.shopCursor-1);
    else if(e.key==='ArrowDown'||e.key==='j')G.shopCursor=Math.min(Math.max(0,entries.length-1),G.shopCursor+1);
    else if(e.key==='PageUp')G.shopCursor=Math.max(0,G.shopCursor-20);
    else if(e.key==='PageDown')G.shopCursor=Math.min(Math.max(0,entries.length-1),G.shopCursor+20);
    else if(e.key==='Home')G.shopCursor=0;
    else if(e.key==='End')G.shopCursor=Math.max(0,entries.length-1);
    else if(e.key==='Enter'){
      if(G.shopMode==='stock'){const it=shop.stock[G.shopCursor];if(it){doBuy(it.name);endTurn();}}
      else {const ent=entries[G.shopCursor];if(ent){doSell(ent.item.name);endTurn();}}
    }
    else if(e.key==='x'||e.key==='X'){
      if(G.shopMode==='stock'){const it=shop.stock[G.shopCursor];if(it)inspectItem(it,'Shop item');}
      else {const ent=entries[G.shopCursor];if(ent)inspectItem(ent.item);}
    }
    else if(e.key==='s'||e.key==='S'){G.shopMode='bag';G.shopCursor=0;G.shopScroll=0;}
    else if(e.key==='b'||e.key==='B'){G.shopMode='stock';G.shopCursor=0;G.shopScroll=0;}
  } else if(G.overlay==='hack'){
    const modes=Object.keys(MODE_SKILL);
    if(e.key==='ArrowUp'||e.key==='k')G.hackCursor=Math.max(0,G.hackCursor-1);
    else if(e.key==='ArrowDown'||e.key==='j')G.hackCursor=Math.min(modes.length-1,G.hackCursor+1);
    else if(e.key==='Enter'){execHack(modes[G.hackCursor]);G.overlay=null;endTurn();}
  } else if(G.overlay==='module_select'){
    const mods=[...G.modules];const loadout=G.hackLoadout;const MAX=10;
    if(e.key==='Escape'){G.overlay=null;render();return;}
    if(e.key==='h'||e.key==='H'){
      if(execHackFromLoadout()){G.overlay=null;endTurn();}
      render();return;
    }
    if(e.key==='ArrowUp'||e.key==='k')G.hackCursor=Math.max(0,G.hackCursor-1);
    else if(e.key==='ArrowDown'||e.key==='j')G.hackCursor=Math.min(Math.min(mods.length,MAX)-1,G.hackCursor+1);
    else if(e.key===' '){
      const mod=mods[G.hackCursor];if(!mod){}
      else{const idx=loadout.indexOf(mod);if(idx>=0)loadout.splice(idx,1);else loadout.push(mod);}
    }
    else if(e.key==='['){
      const mod=mods[G.hackCursor];const idx=loadout.indexOf(mod);
      if(idx>0){[loadout[idx-1],loadout[idx]]=[loadout[idx],loadout[idx-1]];}
    }
    else if(e.key===']'){
      const mod=mods[G.hackCursor];const idx=loadout.indexOf(mod);
      if(idx>=0&&idx<loadout.length-1){[loadout[idx],loadout[idx+1]]=[loadout[idx+1],loadout[idx]];}
    }
    render();return;
  }
}

function doConfront(){
  let target=null,best=999;
  for(const e of Object.values(entities)){
    if(!e.hostile)continue;
    const d=Math.abs(e.x-G.px)+Math.abs(e.y-G.py);
    if(d<best){best=d;target=e;}
  }
  if(!target||best>6){addLog('No enemy to confront.',M.sub);return;}
  const sc=G.skills.social*4+15+(G.rep>0?G.rep:0);
  const roll=ri(0,99);
  G.heat=clampHeat(G.heat+0.05);
  if(roll<sc){
    G.skills.social=(G.skills.social||0)+1;
    target.alerted=false;target.alertTimer=0;
    addLog(`Confronted ${target.name}: social check passed — ${target.name} backs off.`,M.grn);
  } else {
    addLog(`Confronted ${target.name}: social check failed.`,M.red);
    target.alerted=true;target.alertTimer=8;
    if(best<=1)doMeleeAttack(target);
  }
  endTurn();
}

function doRangedShot(dx,dy){
  G.shootMode=false;
  const wpn=G.equipped.weapon;
  if(!wpn||!wpn.range){addLog('No ranged weapon equipped.',M.red);return;}
  const range=wpn.range+(wpn.rangeBonus||0)+Math.floor(G.skills.ranged/3);
  let hit=false;
  for(let r=1;r<=range;r++){
    const tx=G.px+dx*r,ty=G.py+dy*r;
    const c=getc(grid,tx,ty);if(c==='#'||c==='='||c===VOID)break;
    const e=entityAt(tx,ty);
    if(e&&e.hostile){
      scaleEnemy(e);
      const sockAtk=(wpn.sockets||[]).reduce((s,g)=>s+(g.attack||0),0);
      const dmg=Math.max(1,(wpn.attack||1)+sockAtk+ri(0,3)-e.arm);
      e.hp-=dmg;
      addSkillXP('ranged',1);
      if(e.hp<=0){awardKill(e,'shoot down');}
      else{addLog(`Shot ${e.name} for ${dmg}.`,M.yel);e.alerted=true;e.alertTimer=8;}
      G.heat=clampHeat(G.heat+0.5);G.stealthMode=false;hit=true;break;
    }
  }
  if(!hit)addLog('Ranged shot: missed.',M.sub);
  endTurn();
}

// ── Archetype application ──────────────────────────────────────
function applyArchetype(){
  const a=ARCHETYPES[G.archetype];
  for(const[sk,v] of Object.entries(a.skills))G.skills[sk]=(G.skills[sk]||0)+v;
  for(const mod of a.modules){G.modules.add(mod);const t=MODULE_TO_TOOL[mod];if(t)G.tools.add(t);}
  G.walletCp=a.wallet;
  addLog(`Archetype: ${a.label}. ${a.passive}`,M.lav);
}

function applyBonus(){
  G.walletCp=1000;
  const items2=[
    mkItem({char:'[',name:'leather haversack',kind:'backpack',slot:'back',carryBonus:56,bagCap:40,weight:2.5,valueCp:720}),
    mkItem({char:'$',name:'war axe',kind:'weapon',slot:'weapon',attack:25,weight:3.5,valueCp:600,quality:'fine',rarity:'rare'})
  ];
  G.inventory.push(...items2);
  // Give every module needed to hack terminals on this floor that the player doesn't already have
  const floorMods=new Set();
  for(const sp of Object.values(specials)){
    if(sp.kind!=='terminal')continue;
    for(const tool of requiredTools(sp)){
      if(BUILTIN_TOOLS.has(tool))continue;
      const mod=TOOL_TO_MODULE[tool];
      if(mod&&!G.modules.has(mod))floorMods.add(mod);
    }
  }
  for(const mod of floorMods){G.modules.add(mod);const t=MODULE_TO_TOOL[mod];if(t)G.tools.add(t);}
  for(let i=0;i<14;i++){let gem=mkMat();while(gem.material!=='gem')gem=mkMat();G.inventory.push(gem);}
  G.xpMult=3;
  addLog(`START BONUS: haversack, war axe, ${floorMods.size} floor modules, 1000cp, XP ×3.`,M.pch);
  if(floorMods.size)addLog(`  modules: ${[...floorMods].join(', ')}`,M.sub);
}

function restartGame(){
  location.reload();
}

// ── localStorage meta-progression ────────────────────────────
function defaultProfile(){return{unlocked_modules:[],best_daily:null,wins:0,total_wins:0};}
function normalizeProfile(p){
  const d=defaultProfile(),out={...d,...(p||{})};
  out.unlocked_modules=Array.isArray(out.unlocked_modules)?out.unlocked_modules.filter(m=>MODULE_TO_TOOL[m]).slice(-6):[];
  out.wins=Number(out.wins||out.total_wins||0);
  out.total_wins=Number(out.total_wins||out.wins||0);
  return out;
}
function loadProfile(){try{return normalizeProfile(JSON.parse(localStorage.getItem('arthack_save')));}catch{return defaultProfile();}}
function saveProfile(p){try{localStorage.setItem('arthack_save',JSON.stringify(p));}catch{}}
function applyProfileUnlocks(){
  const p=loadProfile();
  const carried=(p.unlocked_modules||[]).slice(0,6);
  for(const mod of carried){G.modules.add(mod);const t=MODULE_TO_TOOL[mod];if(t)G.tools.add(t);}
  if(carried.length)addLog(`[PROFILE] Carried over ${carried.length} module(s): ${carried.join(', ')}.`,M.sky);
}
function onWin(){
  const p=loadProfile();p.wins=(p.wins||0)+1;p.total_wins=(p.total_wins||0)+1;
  const earned=[...G.modules].filter(m=>MODULE_TO_TOOL[m]);
  const merged=[...(p.unlocked_modules||[])];
  for(const mod of earned){const idx=merged.indexOf(mod);if(idx>=0)merged.splice(idx,1);merged.push(mod);}
  p.unlocked_modules=merged.slice(-6);
  if(DAILY){const sc=calcScore();if(!p.best_daily||sc>p.best_daily)p.best_daily=sc;}
  saveProfile(p);
}

// ── Touch controls ────────────────────────────────────────────
function simKey(key){
  const ev=new KeyboardEvent('keydown',{key,bubbles:true,cancelable:true});
  document.dispatchEvent(ev);
}
(function initUI(){
  const link=document.getElementById('mode-link');
  const tui=document.getElementById('touch-ui');
  if(TOUCH_MODE){
    const u=new URL(location.href);u.searchParams.delete('touch');
    link.innerHTML=`<a href="${u.href}">Desktop</a>`;
    tui.style.display='flex';
    // recalculate scale now that touch UI has a real offsetHeight
    requestAnimationFrame(applyScale);
  }else{
    const u=new URL(location.href);u.searchParams.set('touch','1');
    link.innerHTML=`<a href="${u.href}">Touch Mode</a>`;
  }
  // wire all data-key buttons: touchstart → simKey + preventDefault stops ghost click
  document.querySelectorAll('#touch-ui button[data-key]').forEach(b=>{
    const k=b.dataset.key;
    b.addEventListener('touchstart',e=>{e.preventDefault();simKey(k);},{passive:false});
    b.addEventListener('click',()=>simKey(k));
  });
})();

// ── Responsive layout ─────────────────────────────────────────
let _resizeTimer;
window.addEventListener('resize',()=>{
  clearTimeout(_resizeTimer);
  _resizeTimer=setTimeout(()=>{setupLayout();render();},120);
});
window.addEventListener('orientationchange',()=>{
  setTimeout(()=>{setupLayout();render();},200);
});

// ── Init ──────────────────────────────────────────────────────
function init(){
  ctx.font=`${CH}px 'Courier New',monospace`;
  ctx.textBaseline='top';ctx.textAlign='left';
  applyProfileUnlocks();
  G.overlay='archetype';G._archCursor=0;
  render();
}
init();
