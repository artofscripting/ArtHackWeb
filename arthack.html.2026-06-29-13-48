function drawModuleSelect(){
  const term=G.hackTerm;if(!term){G.overlay=null;return;}
  const mode=G.hackMode;
  const scanned=!!term.vulnscanned;
  const reqTools=scanned?new Set(requiredTools(term,mode).filter(t=>!BUILTIN_TOOLS.has(t))):new Set();
  const reqMods=scanned?[...reqTools].map(t=>TOOL_TO_MODULE[t]).filter(Boolean):[];
  const mods=[...G.modules];
  const loadout=G.hackLoadout;
  const MAX=10;

  const needsLine=scanned
    ?(reqMods.length?`Needs: ${reqMods.join(', ')}`:'Needs: (basic tools only)')
    :'Needs: [run portscan + vulnscan]';
  const needsCol=scanned?(reqMods.length?M.pch:M.grn):M.yel;

  overlayText([
    ['═══ MODULE LOADOUT ═══',M.lav,17],
    [`${term.ssid}  ctrl:${term.control}  tier:${term.tier}  mode:${mode}`,M.sub,2],
    [`${term.ip||'?'}  ${term.mac||'?'}  ${term.hostname||'?'}`,M.s1,2],
    ['---'],
    [needsLine,needsCol,2],
    ['---']
  ]);

  let row=6;
  overlayText([['MODULES                   POS',M.yel,2]],2,row++);
  for(let i=0;i<Math.min(mods.length,MAX);i++){
    const mod=mods[i];
    const tool=MODULE_TO_TOOL[mod];
    const isReq=scanned&&reqTools.has(tool);
    const pos=loadout.indexOf(mod);
    const inLoadout=pos>=0;
    const hl=i===G.hackCursor;
    const posStr=inLoadout?`[${pos+1}]`:'[ ]';
    const flag=isReq?'R':' ';
    const col=hl?M.yel:isReq?M.pch:inLoadout?M.grn:M.sub;
    overlayText([[`${hl?'▶':' '} ${mod.padEnd(24)}${flag}${posStr}`,col,2]],2,row++);
  }
  if(mods.length>MAX)overlayText([[`  …${mods.length-MAX} more (type 'show modules')`,M.s1,2]],2,row++);

  // Status
  const missingMods=scanned?[...reqTools].filter(t=>!loadout.some(m=>MODULE_TO_TOOL[m]===t)).map(t=>TOOL_TO_MODULE[t]||t):[];
  const ready=scanned&&missingMods.length===0;
  const statusMsg=!scanned?'Scan target first: portscan → vulnscan':
    missingMods.length?`MISSING: ${missingMods.join(', ')}`:
    loadout.length?'all required modules loaded':'(no modules — basic tools only)';
  const statusCol=!scanned?M.yel:missingMods.length?M.red:loadout.length?M.grn:M.yel;
  overlayText([['---']],2,row++);
  overlayText([[statusMsg,statusCol,2]],2,row++);
  const chanceStr=scanned?`${Math.round(hackChance(term,mode)*100)}% `:' ? ';
  overlayText([[`[${chanceStr}] ${loadout.join('→')||'(empty)'}`,M.blu,2]],2,row++);
  overlayText([[`Spc=toggle  [/]=reorder  ${ready?'h=HACK  ':''}Esc=cancel`,M.sub,2]],2,row);
}

// ── Context-sensitive top bar ────────────────────────────────
function ctxBtn(label,cls,action){
  const b=document.createElement('button');
  b.textContent=label;b.className=cls;
  const fire=e=>{
    if(e)e.preventDefault();
    if(typeof action==='string'){processCmd(action);render();}
    else if(typeof action==='function'){action();render();}
    else simKey(action); // simKey triggers keydown → handler calls render()
  };
  b.addEventListener('touchstart',fire,{passive:false});
  b.addEventListener('click',fire);
  return b;
}

function updateCtxBar(){
  const bar=document.getElementById('ctx-bar');
  if(!bar)return;
  bar.innerHTML='';
  const show=TOUCH_MODE||true; // show on all devices; hide via CSS if desired
  if(!show){bar.style.display='none';return;}
  bar.style.display='flex';

  // sk() wraps a key name so ctxBtn dispatches it via simKey instead of processCmd
  const sk=key=>()=>simKey(key);
  const cmd=(lbl,cls,c)=>bar.appendChild(ctxBtn(lbl,cls,c));      // processCmd
  const key=(lbl,cls,k)=>bar.appendChild(ctxBtn(lbl,cls,sk(k)));  // simKey

  if(G.overlay){
    const ov=G.overlay;
    if(ov==='archetype'){
      key('1-Infiltrate','cb','1');key('2-Combat','cb','2');key('3-Netrunner','cb','3');
      key('ENTER','cg','Enter');
    } else if(ov==='difficulty'){
      key('1-Easy','cg','1');key('2-Normal','cb','2');key('3-Hard','cy','3');key('4-Night','cr','4');
      key('ENTER','cg','Enter');
    } else if(ov==='inventory'){
      key('[1] Gear','cb','1');key('[2] Jewelry','cb','2');key('[3] Modules','cb','3');
      key('EQUIP','cg','e');key('DROP','cr','d');key('USE','cy','u');key('MOVE','cp','m');
      key('ESC','cd','Escape');
    } else if(ov==='craft'){
      key('[R] Recipes','cb','r');key('[S] Socket','cp','s');
      key('FILTER','cy','f');key('CRAFT','cg','Enter');key('ESC','cd','Escape');
    } else if(ov==='shop'){
      key('[B] Buy','cb','b');key('[S] Sell','cp','s');
      key('BUY','cg','Enter');key('ESC','cd','Escape');
    } else if(ov==='module_select'){
      key('TOGGLE','cy',' ');key('◀[','cb','[');key(']▶','cb',']');
      if(G.hackLoadout&&G.hackLoadout.length){
        // Show HACK NOW when loadout covers all required tools (matches in-overlay 'h=HACK' hint)
        const ht=G.hackTerm,hm=G.hackMode||'balanced';
        const reqT=ht?new Set(requiredTools(ht,hm).filter(t=>!BUILTIN_TOOLS.has(t))):new Set();
        const missing=[...reqT].filter(t=>!G.hackLoadout.some(m=>MODULE_TO_TOOL[m]===t));
        if(!missing.length)key('HACK NOW','cg','h');
      }
      key('ESC','cd','Escape');
    } else if(ov==='hack'){
      key('EXEC','cg','Enter');key('ESC','cd','Escape');
    } else if(ov==='log'){
      key('PgUp','cb','PageUp');key('PgDn','cb','PageDown');key('ESC','cd','Escape');
    } else {
      key('CLOSE','cd','Escape');
    }
  } else {
    // ── exploration: terminal-aware commands ──────────────────
    const term=adjTerminal();
    if(term){
      cmd('SCAN','cb','scan');
      cmd('PORTSCAN','cb','portscan');
      if(term.portscanned){
        cmd('VULNSCAN','cb','vulnscan');
        cmd('RECON','cb','hack recon');
      }
      bar.appendChild(ctxBtn('HACK','cb',sk('x')));
      if(term.hacked){
        cmd('BOTNET','cg','botnet');
        cmd('PRACTICE','cg','practice');
        cmd('CLR LOGS','cy','clearlogs');
      }
      if(term.botnet)cmd('PIVOT','cp','pivot');
    } else {
      if(typeof termWithin==='function'&&termWithin(18).length)cmd('SCAN','cb','scan');
    }
  }

  // always add context label on right
  const hadButtons=bar.children.length>0;
  if(hadButtons){
    const lbl=document.createElement('span');
    lbl.style.cssText='margin-left:auto;color:#585b70;font:9px Courier New,monospace;align-self:center;padding-right:2px';
    lbl.textContent=G.overlay?G.overlay.replace('_',' ').toUpperCase():adjTerminal()?'TERMINAL':'';
    bar.appendChild(lbl);
  } else {
    bar.style.display='none';
  }
  // reposition canvas only if bar visibility/height changed
  const newH=hadButtons?bar.offsetHeight:0;
  if(newH!==updateCtxBar._lastH){updateCtxBar._lastH=newH;requestAnimationFrame(applyScale);}
}
updateCtxBar._lastH=0;

function render(){
  ctx.fillStyle=M.base;ctx.fillRect(0,0,CAN_W,CAN_H);
  if(G.overlay){drawOverlay();updateCtxBar();return;}
  if(IS_PORTRAIT){
    drawGameView();drawCompactSidebar();drawLog();
    if(G.showMinimap)drawMinimap();
  }else{
    if(G.showMinimap){drawGameView();drawSidebar();drawLog();drawMinimap();return;}
    drawGameView();drawSidebar();drawLog();
  }
  updateCtxBar();
}

// ── Movement & actions ────────────────────────────────────────
function tryMove(dx,dy){
  const nx=G.px+dx,ny=G.py+dy;
  if(nx<0||nx>=WW||ny<0||ny>=WH)return;
  const cell=grid[ny][nx];
  // Try attack enemy
  const ent=entityAt(nx,ny);
  if(ent&&ent.hostile){doMeleeAttack(ent);endTurn();return;}
  // Try open/unlock door
  const key=`${nx},${ny}`;
  if(cell==='='||cell==='+'){
    const door=doors[key];
    if(door&&door.locked){
      if(door.hack_locked){addLog(`Door is hack-locked [${door.hack_ssid}]. Hack the terminal.`,M.red);}
      else{
        // Check for key in inventory
        const k=G.inventory.find(it=>it.kind==='key');
        if(k){G.inventory=G.inventory.filter(it=>it!==k);door.locked=false;setc(grid,nx,ny,'+');addLog(`Used iron key to unlock door.`,M.grn);endTurn();}
        else{addLog('Door is locked — need a key.',M.red);}
      }
      return;
    }
    if(cell==='+'){G.px=nx;G.py=ny;endTurn();return;}
    if(cell==='='&&door&&!door.locked){setc(grid,nx,ny,'+');G.px=nx;G.py=ny;endTurn();return;}
    return;
  }
  if(BLOCK.has(cell))return;
  // Move
  G.px=nx;G.py=ny;
  // Pick up items
  const it=itemAt(nx,ny);
  if(it){pickupItem(it);}
  // Check specials
  const sp=specials[key];
  if(sp){
    if(sp.kind==='stairs_up'||sp.kind==='stairs_down'){transitionBySpecial(sp);endTurn();return;}
    else if(sp.kind==='gate'&&G.escaped){addLog('The gate is open — you step through!',M.grn);}
    else if(sp.kind==='gate'&&!G.escaped){G.escaped=true;G.phase='return';addLog('You break through the gate! Act 1 complete — now RETURN for the clues.',M.grn);maybeArmPortal();}
    else if(sp.kind==='trapdoor'){transitionBySpecial(sp);endTurn();return;}
    else if(sp.kind==='portal'){
      if(G.portalArmed){G.won=true;G.phase='win';addLog('You step through the portal — ARTHACK COMPLETE!',M.grn);onWin();G.overlay='win';}
      else{addLog('The portal is sealed. Collect all 3 clues first.',M.yel);}
    }
    else if(sp.kind==='loot_chest'){openLootChestAt(nx,ny);}
    else if(sp.kind==='hack_chest'){
      if(sp.locked)addLog('Locked cache chest. Hack its linked terminal to open it.',M.red);
      else releaseHackChestAt(nx,ny);
    }
    else if(sp.kind==='shop'){addLog('Quartermaster nearby. Press p or type shop.',M.pch);}
    else if(sp.kind==='terminal'){addLog(`Odd terminal detected on ${sp.ssid}. Press x to hack.`,M.blu);}
    else if(sp.kind==='station'){addLog(`A ${sp.station==='anvil'?'anvil':'crafting table'} stands here. Press g to craft.`,M.yel);}
  }
  endTurn();
}

function pickupItem(it){
  const fkey=`${it.x},${it.y}`;
  if(it.kind==='currency'){
    G.walletCp+=Number(it.valueCp||0);
    delete items[it.id];grid[it.y][it.x]='.';
    addLog(`Collected ${it.valueCp||0}cp.`,M.yel);return true;
  }
  if(it.kind==='clue'){
    addClue(it.desc,'parchment');
    delete items[it.id];grid[it.y][it.x]='.';return true;
  }
  if(addHeldItem(it)){
    if(it.kind==='module')installModuleItem(it,'found loot');
    delete items[it.id];grid[it.y][it.x]='.';addLog(`Picked up ${it.name}.`,M.yel);
    return true;
  }
  return false;
}

function roomAt(x,y){return rooms.find(r=>x>=r.x0&&x<r.x0+r.w&&y>=r.y0&&y<r.y0+r.h)||null;}
function roomContains(r,x,y){return !!r&&x>=r.x0&&x<r.x0+r.w&&y>=r.y0&&y<r.y0+r.h;}

function placeWorldItem(it,x,y){
  const item={...it,id:`it${++_seq}`,x,y};
  items[item.id]=item;setc(grid,x,y,item.char||'$');
  return item;
}

function openLootChestAt(x,y){
  const key=`${x},${y}`,sp=specials[key];
  if(!sp||sp.kind!=='loot_chest')return false;
  delete specials[key];setc(grid,x,y,'.');
  const names=[];
  for(const loot of sp.loot||[]){
    const[fx,fy]=freeNear(G.px,G.py);
    placeWorldItem(loot,fx,fy);
    names.push(loot.name||'loot');
  }
  addLog(names.length?`You pry open a loot chest: ${names.join(', ')}.`:'The chest is empty.',names.length?M.yel:M.sub);
  return true;
}

function releaseHackChestAt(x,y){
  const key=`${x},${y}`,sp=specials[key];
  if(!sp||sp.kind!=='hack_chest'||sp.locked)return false;
  delete specials[key];setc(grid,x,y,'.');
  const loot=Array.isArray(sp.loot)?sp.loot:[sp.loot].filter(Boolean);
  for(const it of loot)placeWorldItem(it,x,y);
  addLog('Cache chest opens; loot spills onto the floor.',M.grn);
  return true;
}

function releaseLinkedHackChests(term){
  let n=0;
  const tx=term.x??G.px,ty=term.y??G.py;
  for(const[key,sp] of Object.entries(specials)){
    if(sp.kind!=='hack_chest'||sp.ssid!==term.ssid||!sp.locked)continue;
    const[x,y]=key.split(',').map(Number);
    if(Math.abs(x-tx)+Math.abs(y-ty)>16)continue;
    sp.locked=false;
    if(releaseHackChestAt(x,y))n++;
  }
  if(n)addLog(`Linked cache${n>1?'s':''} released: ${n}.`,M.grn);
}

function autoLootRoom(){
  const room=roomAt(G.px,G.py);
  if(!room){addLog('There is no room here to loot.',M.sub);endTurn();return;}
  let moved=false;
  for(const it of Object.values({...items})){
    if(roomContains(room,it.x,it.y)&&pickupItem(it))moved=true;
  }
  for(const[key,sp] of Object.entries({...specials})){
    if(sp.kind!=='loot_chest')continue;
    const[x,y]=key.split(',').map(Number);
    if(roomContains(room,x,y)&&openLootChestAt(x,y)){
      moved=true;
      for(const it of Object.values({...items}))if(roomContains(room,it.x,it.y)&&pickupItem(it))moved=true;
    }
  }
  addLog(moved?'You sweep the room for loot.':'No loose loot found here.',moved?M.yel:M.sub);
  endTurn();
}

function lookAround(){
  const room=roomAt(G.px,G.py);
  addLog(room?`You are in ${room.name||'a chamber'}.`:'You are in a dim passage.',M.sub);
  const here=specials[`${G.px},${G.py}`];
  if(here?.kind==='shop')addLog('Quartermaster nearby. Press p or type shop.',M.pch);
  if(here?.kind==='terminal')addLog(`Odd terminal detected on ${here.ssid}. Press x to hack.`,M.blu);
  if(here?.kind==='station')addLog(`A ${here.station==='anvil'?'anvil':'crafting table'} stands here. Press g to craft.`,M.yel);
  if(here?.kind==='hack_chest'&&here.locked)addLog('Locked cache chest. Root the linked terminal to open it.',M.red);
  const near=Object.entries(specials).filter(([k,sp])=>{
    const[x,y]=k.split(',').map(Number);return Math.abs(x-G.px)+Math.abs(y-G.py)<=3&&['loot_chest','hack_chest','terminal','shop','station'].includes(sp.kind);
  }).length;
  if(near)addLog(`You notice ${near} point(s) of interest nearby.`,M.sky);
