function searchHere(){
  const key=`${G.px},${G.py}`,sp=specials[key];
  let acted=false;
  const it=itemAt(G.px,G.py);
  if(it){acted=pickupItem(it)||acted;}
  if(sp?.kind==='loot_chest')acted=openLootChestAt(G.px,G.py)||acted;
  else if(sp?.kind==='hack_chest'){
    if(sp.locked)addLog('The cache is locked to a terminal session.',M.red);
    else acted=releaseHackChestAt(G.px,G.py)||acted;
  }
