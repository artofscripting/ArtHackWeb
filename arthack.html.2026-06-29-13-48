function invCount(material){return [...G.inventory,...G.backpackInv].filter(it=>it.material===material).length;}
function equippedItems(){return Object.values(G.equipped).filter(Boolean);}
function itemWeight(it){return Number(it?.weight||0);}
function socketStatLine(it){
  if(!it)return'';
  const parts=[];
  if(it.attack)parts.push(`+${it.attack}atk`);
  if(it.defense)parts.push(`+${it.defense}def`);
  if(it.sightBonus)parts.push(`+${it.sightBonus}sight`);
  if(it.range||it.rangeBonus)parts.push(`r${Number(it.range||0)+Number(it.rangeBonus||0)}`);
  if(it.carryBonus)parts.push(`+${it.carryBonus}carry`);
  if(it.bagCap||it.bagSlots)parts.push(`+${it.bagCap||it.bagSlots}slots`);
  if(it.hackBonus)parts.push(`+${it.hackBonus}hack`);
  return parts.join(' ');
}
function inspectItem(it,label='Inspect'){
  if(!it){addLog('Nothing to inspect.',M.sub);return;}
  addLog(`${label}: ${it.name}`,M.blu);
  if(it.desc)addLog(`  ${it.desc}`,M.sub);
  addLog(`  Kind: ${it.kind||'item'}  Slot: ${it.slot||'none'}  ${socketStatLine(it)}`,M.sub);
  if(it.quality||it.rarity)addLog(`  Quality: ${it.quality||'common'}  Rarity: ${it.rarity||'common'}`,M.sub);
  if(it.material)addLog(`  Material: ${it.material}`,M.sub);
  if(it.enchantment)addLog(`  Enchantment: ${it.enchantment}`,M.pch);
  if(it.range||it.rangeBonus)addLog(`  Range: ${Number(it.range||0)+Number(it.rangeBonus||0)}`,M.sub);
  if(it.carryBonus)addLog(`  Carry bonus: +${it.carryBonus}`,M.sub);
  if(it.bagCap||it.bagSlots)addLog(`  Bag slots: ${it.bagCap||it.bagSlots}`,M.sub);
  if(it.sockets?.length)addLog(`  Sockets: ${it.sockets.length} (${it.sockets.map(s=>s.gem||'gem').join(', ')})`,M.tea);
  if(it.kind==='potion'&&POTION_FX[it.name]){
    const fx=POTION_FX[it.name];
    addLog(`  Potion: heal ${fx.heal||0}, duration ${fx.duration||0}, atk +${fx.attack||0}, def +${fx.defense||0}, regen ${fx.regen||0}`,M.grn);
  }
  addLog(`  Weight: ${itemWeight(it).toFixed(1)}  Value: ${Number(it.valueCp||0)}cp`,M.sub);
}
function inspectRecipe(recipe){
  if(!recipe){addLog('No recipe selected.',M.sub);return;}
  const res=recipe.result||{};
  const inputs=Object.entries(recipe.inputs||{}).map(([m,n])=>`${n}x ${m}`).join(', ')||'none';
  addLog(`Recipe: ${recipe.name}`,M.blu);
  addLog(`  Needs: ${inputs}${recipe.station?` @ ${recipe.station}`:' (no station)'}`,canCraft(recipe)?M.grn:M.yel);
  addLog(`  Makes: ${res.name||'item'} (${res.kind||'item'}) ${socketStatLine(res)}`,M.sub);
  if(res.desc)addLog(`  ${res.desc}`,M.sub);
}
function carryBonus(){
  let b=0;
  for(const it of equippedItems()){
    b+=Number(it.carryBonus||0);
    for(const sock of (it.sockets||[]))b+=Number(sock.carryBonus||0);
  }
  return b;
}
function hackBonus(){
  let b=0;
  for(const it of equippedItems()){
    b+=Number(it.hackBonus||0);
    for(const sock of (it.sockets||[]))b+=Number(sock.hackBonus||0);
  }
  return b;
}
function maxCarry(){return G.maxWeight+carryBonus();}
function backpackCapacity(){
  const bp=G.equipped.back;
  if(!bp)return 0;
  return Number(bp.bagCap||bp.bagSlots||0)+(bp.sockets||[]).reduce((s,g)=>s+Number(g.bagSlots||0),0);
}
function invWeight(){
  return [...G.inventory,...G.backpackInv,...equippedItems()].reduce((s,it)=>s+itemWeight(it),0);
}
function installModuleItem(it,source='module'){
  const mod=it.module||Object.keys(MODULE_TO_TOOL).find(k=>it.name.toLowerCase().includes(k));
  if(!mod)return false;
  unlockModule(mod,source);
  return true;
}
function removeHeldItem(it){
  let idx=G.inventory.indexOf(it);
  if(idx>=0){G.inventory.splice(idx,1);return'bag';}
  idx=G.backpackInv.indexOf(it);
  if(idx>=0){G.backpackInv.splice(idx,1);return'backpack';}
  return null;
}
function heldItemOrigin(it){
  if(G.inventory.includes(it))return'bag';
  if(G.backpackInv.includes(it))return'backpack';
  return null;
}
function findHeldItem(name,pred=()=>true){
  const n=(name||'').toLowerCase();
  return [...G.inventory,...G.backpackInv].find(it=>it.name.toLowerCase().includes(n)&&pred(it));
}
function inventoryEntries(){
  let arr=[];
  if(G.invView==='gear'){
    arr.push(...['weapon','armor_head','armor_chest','armor_legs','shield','back'].map(slot=>G.equipped[slot]?{origin:'equipped',slot,item:G.equipped[slot]}:null).filter(Boolean));
    arr.push(...G.inventory.filter(it=>['weapon','armor','backpack','potion','item','material','currency','key','clue'].includes(it.kind)).map(item=>({origin:'bag',slot:item.slot,item})));
    arr.push(...G.backpackInv.filter(it=>it.kind!=='jewelry'&&it.kind!=='module').map(item=>({origin:'backpack',slot:item.slot,item})));
  } else if(G.invView==='jewelry'){
    arr.push(...['amulet','ring_1','ring_2','ring_3','ring_4','ring_5','ring_6','ring_7','ring_8','ring_9','ring_10'].map(slot=>G.equipped[slot]?{origin:'equipped',slot,item:G.equipped[slot]}:null).filter(Boolean));
    arr.push(...[...G.inventory,...G.backpackInv].filter(it=>it.kind==='jewelry'||it.slot==='ring'||it.slot==='amulet').map(item=>({origin:G.inventory.includes(item)?'bag':'backpack',slot:item.slot,item})));
  } else {
    arr.push(...[...G.inventory,...G.backpackInv].filter(it=>it.kind==='module').map(item=>({origin:G.inventory.includes(item)?'bag':'backpack',slot:item.slot,item})));
  }
  return arr;
}
function canHoldItem(it){
  if(invWeight()+itemWeight(it)>maxCarry())return false;
  if(G.inventory.length<G.maxInv)return true;
  return !!(backpackCapacity()&&G.backpackInv.length<backpackCapacity());
}
function addHeldItem(it){
  if(invWeight()+itemWeight(it)>maxCarry()){addLog('Too heavy to pick up.',M.red);return false;}
  if(G.inventory.length<G.maxInv){G.inventory.push(it);return true;}
  const cap=backpackCapacity();
  if(cap&&G.backpackInv.length<cap){G.backpackInv.push(it);addLog(`Bag full — ${it.name} -> backpack (${G.backpackInv.length}/${cap}).`,M.yel);return true;}
  addLog(`Inventory full (${G.maxInv} + backpack ${cap}).`,M.red);
  return false;
}
function canCraft(recipe){
  const adj=adjStation(recipe.station);
  if(recipe.station&&!adj)return false;
  for(const[mat,n] of Object.entries(recipe.inputs))if(invCount(mat)<n)return false;
  return true;
}
function adjStation(station){
  if(!station)return true;
  for(let dy=-1;dy<=1;dy++)for(let dx=-1;dx<=1;dx++){
    const sp=specials[`${G.px+dx},${G.py+dy}`];
    if(sp&&sp.kind==='station'&&sp.station===station)return true;
  }return false;
}
function socketableItems(){
  const arr=[];
  for(const slot of ['weapon','armor_head','armor_chest','armor_legs','shield','back']){
    const it=G.equipped[slot];
    if(it&&(slot!=='weapon'||it.range>0))arr.push({origin:'equipped',slot,item:it});
  }
  for(const it of [...G.inventory,...G.backpackInv]){
    const ok=it.kind==='backpack'||it.kind==='armor'||(it.kind==='weapon'&&it.range>0);
    if(ok)arr.push({origin:G.inventory.includes(it)?'bag':'backpack',slot:it.slot,item:it});
  }
  return arr;
}
function availableGems(){return [...G.inventory,...G.backpackInv].filter(it=>it.kind==='material'&&it.material==='gem');}
function gemPreviewLines(item,gem){
  const lines=[];
  if(item.kind==='backpack'){
    if(gem.carryBonus)lines.push(`Preview: ${item.name} carry +${gem.carryBonus}.`);
    if(gem.bagSlots)lines.push(`Preview: ${item.name} slots +${gem.bagSlots}.`);
    if(gem.hackBonus)lines.push(`Preview: equipped hack bonus +${gem.hackBonus}.`);
  } else if(item.kind==='weapon'&&item.range>0){
    if(gem.attack)lines.push(`Preview: ranged damage +${gem.attack}.`);
    if(gem.sightBonus)lines.push(`Preview: range +${gem.sightBonus}.`);
    if(gem.carryBonus)lines.push(`Preview: equipped carry +${gem.carryBonus}.`);
    if(gem.hackBonus)lines.push(`Preview: equipped hack bonus +${gem.hackBonus}.`);
  } else {
    if(gem.attack)lines.push(`Preview: attack +${gem.attack}.`);
    if(gem.defense)lines.push(`Preview: defense +${gem.defense}.`);
    if(gem.sightBonus)lines.push(`Preview: sight +${gem.sightBonus}.`);
    if(gem.carryBonus)lines.push(`Preview: equipped carry +${gem.carryBonus}.`);
    if(gem.hackBonus)lines.push(`Preview: equipped hack bonus +${gem.hackBonus}.`);
  }
  return lines.length?lines:['Preview: value socket only.'];
}
function socketGem(item,gem){
  if(!adjStation('anvil')){addLog('Socketing requires a nearby anvil.',M.red);return false;}
  if(!item||!gem){addLog('Choose gear and a gem first.',M.red);return false;}
  if(!availableGems().includes(gem)){addLog('Gem is no longer available.',M.red);return false;}
  item.sockets=item.sockets||[];
  const sock={gem:gem.name};
  if(item.kind==='backpack'){
    if(gem.carryBonus)sock.carryBonus=gem.carryBonus;
    if(gem.bagSlots)sock.bagSlots=gem.bagSlots;
    if(gem.hackBonus)sock.hackBonus=gem.hackBonus;
  } else if(item.kind==='weapon'&&item.range>0){
    if(gem.attack)sock.attack=gem.attack;
    if(gem.sightBonus){item.rangeBonus=Number(item.rangeBonus||0)+gem.sightBonus;sock.rangeBonus=gem.sightBonus;}
    if(gem.carryBonus)sock.carryBonus=gem.carryBonus;
    if(gem.hackBonus)sock.hackBonus=gem.hackBonus;
  } else {
    if(gem.attack){item.attack=Number(item.attack||0)+gem.attack;sock.attack=gem.attack;}
    if(gem.defense){item.defense=Number(item.defense||0)+gem.defense;sock.defense=gem.defense;}
    if(gem.sightBonus){item.sightBonus=Number(item.sightBonus||0)+gem.sightBonus;sock.sightBonus=gem.sightBonus;}
    if(gem.carryBonus)sock.carryBonus=gem.carryBonus;
    if(gem.hackBonus)sock.hackBonus=gem.hackBonus;
  }
  item.valueCp=Number(item.valueCp||0)+Number(gem.valueCp||0);
  item.sockets.push(sock);
  removeHeldItem(gem);
  computeVisible(visionRadius());
  addLog(`Socketed ${gem.name} into ${item.name}.`,M.grn);
  return true;
}
function doCraft(recipe){
  if(!canCraft(recipe)){addLog('Cannot craft — missing materials or not at required station.',M.red);return;}
  const r={...recipe.result,id:`it${++_seq}`,x:0,y:0};
  if(!canHoldItem(r)){addLog('No room for crafted item; materials kept.',M.red);return;}
  for(const[mat,n] of Object.entries(recipe.inputs)){
    let rem=n;
    G.inventory=G.inventory.filter(it=>{if(it.material===mat&&rem>0){rem--;return false;}return true;});
    G.backpackInv=G.backpackInv.filter(it=>{if(it.material===mat&&rem>0){rem--;return false;}return true;});
  }
  if(!addHeldItem(r)){addLog('No room for crafted item; materials kept.',M.red);return;}
  if(r.module){G.modules.add(r.module);const tool=MODULE_TO_TOOL[r.module];if(tool)G.tools.add(tool);addLog(`Crafted ${r.name}. Tool unlocked: ${tool||'?'}`,M.grn);}
  else{addLog(`Crafted ${r.name}.`,M.grn);}
  if(r.kind==='module'){G.stats.modules_crafted++;G.skills.persist=(G.skills.persist||0)+1;}
}

// ── Shop ─────────────────────────────────────────────────────
function currentShop(){
  for(let dy=-1;dy<=1;dy++)for(let dx=-1;dx<=1;dx++){
    const sp=specials[`${G.px+dx},${G.py+dy}`];
    if(sp&&sp.kind==='shop')return sp;
  }
  return null;
}
function sellPrice(it){return Math.max(1,Math.floor(Number(it.valueCp||0)*0.6));}
function sellEntries(){
  return [...G.inventory.map(item=>({origin:'bag',item})),...G.backpackInv.map(item=>({origin:'backpack',item}))]
    .filter(({item})=>!['key','clue','currency'].includes(item.kind));
}
function doBuy(name){
  const shop=currentShop();if(!shop){addLog('Not at a shop.',M.red);return;}
  const token=String(name||'').trim();
  const numeric=/^\d+$/.test(token);
  const idx=numeric?Number(token)-1:shop.stock.findIndex(it=>it.name.toLowerCase().includes(token.toLowerCase()));
  if(idx<0){addLog(`Not in stock: ${name}`,M.red);return;}
  const it=shop.stock[idx];
  if(!it){addLog('No such shop item.',M.red);return;}
  if(G.walletCp<it.valueCp){addLog(`Need ${it.valueCp}cp. Have ${G.walletCp}cp.`,M.red);return;}
  const bought={...it,id:`it${++_seq}`};
  if(!addHeldItem(bought))return;
  G.walletCp-=it.valueCp;shop.stock.splice(idx,1);
  if(bought.kind==='module')installModuleItem(bought,'bought module');
  addLog(`Bought ${it.name} for ${it.valueCp}cp.`,M.grn);
}
function doSell(name){
  const shop=currentShop();if(!shop){addLog('Not at a shop.',M.red);return;}
  const it=findHeldItem(name);
  if(!it){addLog(`Not in inventory: ${name}`,M.red);return;}
  if(['key','clue','currency'].includes(it.kind)){addLog('Cannot sell quest items or loose coin.',M.red);return;}
  removeHeldItem(it);
  const payout=sellPrice(it);
  G.walletCp+=payout;
  if(shop.stock.length<20)shop.stock.push({...it,id:`shop_sell_${++_seq}`,valueCp:Math.max(1,Math.floor(Number(it.valueCp||0)*0.85))});
  addLog(`Sold ${it.name} for ${payout}cp.`,M.grn);
}

// ── Equip/use ─────────────────────────────────────────────────
function doEquip(name){
  const it=findHeldItem(name);
  if(!it){addLog(`Not found: ${name}`,M.red);return;}
  let slot=it.slot;
  if(slot==='ring'){slot=Object.keys(G.equipped).find(s=>s.startsWith('ring_')&&!G.equipped[s])||'ring_1';}
  if(!slot||slot==='none'){addLog(`${it.name} cannot be equipped.`,M.red);return;}
  if(slot==='back'&&G.backpackInv.length>Number(it.bagCap||0)){addLog(`${it.name} cannot hold current backpack contents.`,M.red);return;}
  const origin=removeHeldItem(it);
  if(!origin){addLog(`${it.name} is not in inventory.`,M.red);return;}
  if(G.equipped[slot]){
    const old=G.equipped[slot];
    if(origin==='backpack')G.backpackInv.push(old);else G.inventory.push(old);
    addLog(`Unequipped ${old.name}.`,M.sub);
  }
  G.equipped[slot]=it;
  if(it.module){G.modules.add(it.module);const t=MODULE_TO_TOOL[it.module];if(t)G.tools.add(t);}
  addLog(`Equipped ${it.name}.`,M.grn);
  computeVisible(visionRadius());
}
function doUnequip(slotName){
  const alias={head:'armor_head',chest:'armor_chest',legs:'armor_legs',armor:'armor_chest',backpack:'back',pack:'back',ring1:'ring_1',ring2:'ring_2',ring3:'ring_3',ring4:'ring_4',ring5:'ring_5',ring6:'ring_6',ring7:'ring_7',ring8:'ring_8',ring9:'ring_9',ring10:'ring_10'};
  const slot=alias[slotName]||slotName;
  const it=G.equipped[slot];
  if(!it){addLog(`Nothing in slot: ${slotName}`,M.red);return;}
  if(slot==='back'&&G.backpackInv.length){addLog('Empty backpack before unequipping it.',M.red);return;}
  if(G.inventory.length<G.maxInv)G.inventory.push(it);
  else if(backpackCapacity()&&G.backpackInv.length<backpackCapacity())G.backpackInv.push(it);
  else{addLog('No room to unequip that item.',M.red);return;}
  G.equipped[slot]=null;
  addLog(`Unequipped ${it.name}.`,M.sub);
  computeVisible(visionRadius());
}
function doDrink(name){
  const it=findHeldItem(name,it=>it.kind==='potion');
  if(!it){addLog(`Potion not found: ${name}`,M.red);return;}
  removeHeldItem(it);
  const fx=POTION_FX[it.name];
  if(!fx){G.hp=Math.min(G.maxHp,G.hp+10);addLog(`Drank ${it.name}. +10 HP.`,M.grn);return;}
  G.hp=Math.min(G.maxHp,G.hp+fx.heal);
  if(fx.duration>0&&fx.attack)G.activeEffects.push({name:it.name,type:'attack',value:fx.attack,duration:fx.duration});
  if(fx.duration>0&&fx.defense)G.activeEffects.push({name:it.name,type:'defense',value:fx.defense,duration:fx.duration});
  if(fx.duration>0&&fx.sight)G.activeEffects.push({name:it.name,type:'sight',value:fx.sight,duration:fx.duration});
  if(fx.regen>0)G.activeEffects.push({name:it.name+' regen',type:'regen',value:fx.regen,duration:fx.duration});
  addLog(`Drank ${it.name}.${fx.heal?' +'+fx.heal+' HP':''}${fx.attack?' +'+fx.attack+' atk':''}`,M.grn);
  computeVisible(visionRadius());
}

function doDrop(name){
  if(!name){addLog('Usage: drop <item name>',M.red);return false;}
  const it=findHeldItem(name);
  if(!it){addLog('That item is not in your inventory.',M.red);return false;}
  const origin=removeHeldItem(it);
  if(!origin){addLog('Unequip or stash that item before dropping it.',M.red);return false;}
  placeWorldItem(it,G.px,G.py);
  addLog(`Dropped ${it.name} at your feet.`,M.yel);
  computeVisible(visionRadius());
  return true;
}

function doMoveItem(name,target=null){
  if(!name){addLog('Usage: move <item name> [to backpack|to inventory]',M.red);return false;}
  const it=findHeldItem(name);
  if(!it){addLog('That item is not in your inventory.',M.red);return false;}
  const origin=heldItemOrigin(it);
  if(origin==='bag'){
    if(target&&target!=='backpack'){addLog('That item is already in main inventory.',M.sub);return false;}
    const cap=backpackCapacity();
    if(!cap){addLog('Equip a backpack first, or drop the item instead.',M.red);return false;}
    if(G.backpackInv.length>=cap){addLog('Your backpack is full.',M.red);return false;}
    G.inventory.splice(G.inventory.indexOf(it),1);
    G.backpackInv.push(it);
    addLog(`Moved ${it.name} into the backpack.`,M.grn);
    return true;
  }
  if(origin==='backpack'){
    if(target&&target!=='inventory'&&target!=='bag'){addLog('That item is already in the backpack.',M.sub);return false;}
    if(G.inventory.length>=G.maxInv){addLog('Main inventory is full.',M.red);return false;}
    G.backpackInv.splice(G.backpackInv.indexOf(it),1);
    G.inventory.push(it);
    addLog(`Moved ${it.name} into main inventory.`,M.grn);
    return true;
  }
  addLog('That item cannot be moved right now.',M.red);
  return false;
}

// ── Level transitions ──────────────────────────────────────────
function saveCurrentLevel(){
  const snap=levelStore[G.level];
  snap.grid=grid.map(r=>[...r]);
  snap.rooms=[...rooms];
  snap.items={...items};
  snap.entities={...entities};
  snap.doors=Object.fromEntries(Object.entries(doors).map(([k,v])=>[k,{...v}]));
  snap.specials=Object.fromEntries(Object.entries(specials).map(([k,v])=>[k,{...v}]));
  snap.seen=new Set(seen);
}
function loadLevel(n,x=null,y=null){
  saveCurrentLevel();
  const snap=levelStore[n];
  grid=snap.grid.map(r=>[...r]);
  rooms=[...snap.rooms];
  items={...snap.items};
  entities={...snap.entities};
  doors=Object.fromEntries(Object.entries(snap.doors).map(([k,v])=>[k,{...v}]));
  specials=Object.fromEntries(Object.entries(snap.specials).map(([k,v])=>[k,{...v}]));
  seen=new Set(snap.seen);visible=new Set();
  G.level=n;
  if(Number.isInteger(x)&&Number.isInteger(y)){G.px=x;G.py=y;}
  else{
    const f=rooms.flatMap(r=>floorCells(grid,r));
    const p=f.find(([fx,fy])=>!entityAt(fx,fy))||f[0];
    if(p){[G.px,G.py]=p;}
  }
  initEnemyPatrols();
  computeVisible(visionRadius());
}

function transitionBySpecial(sp){
  const from=G.level;
  loadLevel(sp.targetLevel,sp.targetX,sp.targetY);
  const label=G.level>from?'You climb to the next level.':G.level<from?'You descend to the level below.':'You pass through the stairwell.';
  addLog(label,M.blu);
}

// ── Contracts ─────────────────────────────────────────────────
function generateContracts(){
  const rootN=ri(2,3),craftN=ri(2,3),nodeN=ri(1,2);
  G.contracts=[
    {type:'terminal',n:rootN,desc:`Root ${rootN} terminals`,progress:0,reward:180*rootN,done:false},
    {type:'craft',n:craftN,desc:`Craft ${craftN} modules`,progress:0,reward:120*craftN,done:false},
    {type:'botnet',n:nodeN,desc:`Install ${nodeN} C2 nodes`,progress:0,reward:250*nodeN,done:false}
  ];
}
function contractProgress(c){
  if(c.type==='terminal')return Math.min(c.n,G.stats.terminals_rooted||0);
  if(c.type==='craft')return Math.min(c.n,G.stats.modules_crafted||0);
  if(c.type==='botnet')return Math.min(c.n,G.stats.botnets||0);
  return 0;
}
function contractDone(c){
  return contractProgress(c)>=c.n;
}
function checkContracts(){
  for(const c of G.contracts){
    if(!c.done&&contractDone(c)){c.done=true;G.walletCp+=c.reward;G.stats.contracts_done++;addLog(`Contract complete: "${c.desc}" +${c.reward}cp!`,M.grn);adjustRep(2,'contract fulfilled');}
  }
}

// ── Score ─────────────────────────────────────────────────────
function calcScore(){
  return Math.max(0,
    (G.stats.terminals_rooted||0)*100+
    (G.stats.contracts_done||0)*250+
    (G.stats.kills||0)*25+
    G.clues*50+
    (G.won?500:0)-
    G.turnCount-
    Math.floor((G.heatPeak||G.heat||0)*40)
  );
}

